---
import type { CollectionEntry } from 'astro:content';

import { sitePath } from '../../config/site';
import ArtifactSketch from './ArtifactSketch.astro';
import WorkArtifact from './WorkArtifact.astro';
import WorkModeNav from './WorkModeNav.astro';

interface Props {
  current: 'software' | 'games';
  title: string;
  entries: Array<CollectionEntry<'software'> | CollectionEntry<'games'>>;
}

const { current, title, entries } = Astro.props;

const sectionLabels = {
  featured: current === 'software' ? 'Software projects' : 'Finished games',
  supporting: 'Supporting work',
  trajectory: 'Earlier experiments',
} as const;

const groups = (['featured', 'supporting', 'trajectory'] as const)
  .map((prominence) => ({
    prominence,
    entries: entries.filter((entry) => entry.data.prominence === prominence),
  }))
  .filter((group) => group.entries.length > 0);

const entryAnnotations = (entry: CollectionEntry<'software'> | CollectionEntry<'games'>) => {
  if ('capabilities' in entry.data) return entry.data.capabilities;
  return [entry.data.engine, entry.data.jam].filter((value): value is string => Boolean(value));
};

const entryResult = (entry: CollectionEntry<'software'> | CollectionEntry<'games'>) =>
  'result' in entry.data ? entry.data.result : undefined;

---

<div class:list={['work-inventory', `work-inventory--${current}`]}>
  <svg class="work-inventory__boundary" viewBox="0 0 1000 1800" preserveAspectRatio="none" aria-hidden="true">
    <path class="work-inventory__boundary-left" d="M25 18 C12 188 35 342 21 516 C9 681 34 833 20 1003 C8 1170 33 1324 18 1493 C12 1599 26 1690 20 1778" />
    <path class="work-inventory__boundary-left-echo" d="M37 43 C28 201 44 356 32 521 C21 684 46 846 31 1008" />
    <path class="work-inventory__boundary-right" d="M979 37 C990 193 967 360 981 527 C990 695 971 851 984 1021 C992 1180 971 1337 984 1507" />
  </svg>

  <WorkModeNav current={current} />

  <header class="work-inventory__introduction">
    <div class="work-inventory__title">
      <p>work / {current}</p>
      <h1>{title}</h1>
    </div>
  </header>

  {
    groups.map((group) => (
      <section class:list={['work-inventory__group', `work-inventory__group--${group.prominence}`]} aria-labelledby={`${current}-${group.prominence}`}>
        <h2 class="sr-only" id={`${current}-${group.prominence}`}>{sectionLabels[group.prominence]}</h2>
        <div class="work-inventory__artifacts">
          {group.entries.map((entry) => (
            <WorkArtifact
              title={entry.data.title}
              prominence={entry.data.prominence}
              status={entry.data.status}
              annotations={entryAnnotations(entry)}
              result={entryResult(entry)}
              externalUrl={entry.data.externalUrl}
            >
              <ArtifactSketch slot="sketch" category={current} slug={entry.id} />
            </WorkArtifact>
          ))}
        </div>
      </section>
    ))
  }

  {
    current === 'software' && (
      <aside class="work-inventory__resume" aria-labelledby="resume-label">
        <p id="resume-label">résumé</p>
        <div>
          <a href={sitePath('/resume/igor-kupchinenko-resume.pdf')} download>résumé PDF</a>
          <a href={sitePath('/resume/igor-kupchinenko-resume.docx')} download>résumé DOCX</a>
        </div>
      </aside>
    )
  }
</div>

<style>
  .work-inventory {
    --work-accent: #86aebd;

    position: relative;
    isolation: isolate;
    display: grid;
    gap: clamp(4rem, 9vw, 8rem);
    min-height: calc(100vh - (2 * var(--field-gutter)));
    padding: clamp(1.25rem, 4vw, 3.75rem) clamp(1.75rem, 5vw, 5rem) clamp(3rem, 7vw, 6rem);
  }

  .work-inventory--games {
    --work-accent: #d98b7f;
  }

  .work-inventory__boundary {
    position: absolute;
    z-index: -1;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .work-inventory__boundary path {
    fill: none;
    stroke: rgba(243, 239, 228, 0.68);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .work-inventory__boundary .work-inventory__boundary-left-echo {
    stroke: color-mix(in srgb, var(--work-accent) 45%, transparent);
    stroke-width: 1.2;
  }

  .work-inventory__boundary-right {
    stroke: rgba(243, 239, 228, 0.24) !important;
  }

  .work-inventory__introduction {
    position: relative;
    z-index: 1;
    display: flex;
    min-height: clamp(17rem, 32vw, 25rem);
    align-items: center;
    padding-left: clamp(0rem, 4vw, 3rem);
  }

  .work-inventory__title {
    display: grid;
    gap: 0.25rem;
  }

  .work-inventory__title > p {
    width: fit-content;
    color: rgba(243, 239, 228, 0.58);
    font-size: 0.95rem;
    transform: rotate(-2deg);
  }

  .work-inventory__introduction h1 {
    font-family: var(--font-distinctive);
    font-size: clamp(3.4rem, 8vw, 7.25rem);
    font-weight: 400;
    line-height: 0.9;
    transform: rotate(-2deg);
  }

  .work-inventory__group {
    position: relative;
    display: grid;
    padding-left: clamp(0rem, 1vw, 0.75rem);
  }

  .work-inventory__artifacts {
    display: grid;
    gap: clamp(0rem, 2vw, 1.5rem);
  }

  .work-inventory__group--trajectory .work-inventory__artifacts {
    grid-template-columns: repeat(2, minmax(0, 1fr));
    gap: clamp(1.5rem, 4vw, 4rem);
  }

  .work-inventory__group--trajectory .work-inventory__artifacts :global(.work-artifact) {
    grid-template-columns: minmax(0, 0.55fr) minmax(0, 1.45fr);
  }

  .work-inventory__group--trajectory .work-inventory__artifacts :global(.work-artifact:nth-child(2)) {
    margin-top: clamp(4rem, 9vw, 8rem);
  }

  .work-inventory__resume {
    position: relative;
    display: grid;
    grid-template-columns: minmax(0, 0.7fr) minmax(16rem, 1.3fr);
    gap: 1.5rem;
    width: min(100%, 43rem);
    align-items: center;
    justify-self: end;
    padding: 1.5rem 1.75rem;
    border-top: 0.12rem dashed rgba(243, 239, 228, 0.3);
    transform: rotate(-1deg);
  }

  .work-inventory__resume > p {
    font-family: var(--font-distinctive);
    font-size: clamp(1.6rem, 3vw, 2.3rem);
    line-height: 1.05;
  }

  .work-inventory__resume > div {
    display: flex;
    flex-wrap: wrap;
    gap: 0.75rem 1.25rem;
  }

  .work-inventory__resume a {
    min-height: 2.75rem;
    padding-block: 0.55rem;
    color: var(--color-field-ink);
    text-underline-offset: 0.2em;
  }

  @media (max-width: 48rem) {
    .work-inventory__resume {
      grid-template-columns: minmax(0, 1fr);
    }

    .work-inventory__introduction {
      min-height: auto;
    }

    .work-inventory__group--trajectory .work-inventory__artifacts {
      grid-template-columns: minmax(0, 1fr);
    }

    .work-inventory__group--trajectory .work-inventory__artifacts :global(.work-artifact) {
      grid-template-columns: minmax(0, 1fr);
    }

    .work-inventory__group--trajectory .work-inventory__artifacts :global(.work-artifact:nth-child(2)) {
      margin-top: 0;
    }
  }

  @media (max-width: 36rem) {
    .work-inventory {
      gap: 4.5rem;
      padding: 1.25rem 1rem 3rem 1.4rem;
    }

    .work-inventory__boundary-left-echo,
    .work-inventory__boundary-right {
      display: none;
    }

    .work-inventory__introduction {
      gap: 1.5rem;
    }

    .work-inventory__introduction h1 {
      font-size: clamp(3.2rem, 20vw, 5.1rem);
    }

    .work-inventory__group {
      padding-left: 0;
    }

    .work-inventory__resume {
      padding-inline: 0.8rem;
    }
  }
</style>
