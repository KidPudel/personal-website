---
import { sitePath } from '../../config/site';

interface Props {
  current: 'software' | 'games';
}

const { current } = Astro.props;
---

<nav class="work-mode-nav" aria-label="Work areas">
  <a class="work-mode-nav__index" href={`${sitePath('/')}#work`}>
    <span aria-hidden="true">←</span> work choices
  </a>
  <span class="work-mode-nav__trail" aria-hidden="true"></span>
  <div class="work-mode-nav__modes">
    <a
      class:list={['work-mode-nav__mode', { 'is-current': current === 'software' }]}
      href={sitePath('/work/software/')}
      aria-current={current === 'software' ? 'page' : undefined}
    >
      Software
    </a>
    <span aria-hidden="true">/</span>
    <a
      class:list={['work-mode-nav__mode', { 'is-current': current === 'games' }]}
      href={sitePath('/work/games/')}
      aria-current={current === 'games' ? 'page' : undefined}
    >
      Games
    </a>
  </div>
</nav>

<style>
  .work-mode-nav {
    position: relative;
    z-index: 3;
    display: grid;
    grid-template-columns: max-content minmax(2rem, 1fr) max-content;
    align-items: center;
    gap: 0.8rem;
  }

  .work-mode-nav a {
    color: var(--color-field-ink);
  }

  .work-mode-nav__index {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    gap: 0.35rem;
    padding: 0.55rem 0.25rem;
    font-size: 0.95rem;
    text-underline-offset: 0.2em;
    transform: rotate(-2deg);
  }

  .work-mode-nav__trail {
    width: 100%;
    height: 0.75rem;
    border-top: 0.1rem solid rgba(243, 239, 228, 0.34);
    border-radius: 50%;
    transform: translateY(0.25rem) rotate(-0.8deg);
  }

  .work-mode-nav__modes {
    display: flex;
    align-items: center;
    gap: 0.55rem;
    color: rgba(243, 239, 228, 0.38);
  }

  .work-mode-nav__mode {
    position: relative;
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    padding: 0.55rem 0.3rem;
    font-size: 1.05rem;
    text-decoration: none;
    opacity: 0.58;
  }

  .work-mode-nav__mode::after {
    position: absolute;
    right: 0.1rem;
    bottom: 0.38rem;
    left: 0.05rem;
    height: 0.12rem;
    border-radius: 50%;
    background: var(--work-accent);
    content: '';
    opacity: 0;
    transform: rotate(-1.5deg);
  }

  .work-mode-nav__mode.is-current {
    opacity: 1;
  }

  .work-mode-nav__mode.is-current::after {
    opacity: 0.9;
  }

  @media (max-width: 36rem) {
    .work-mode-nav {
      grid-template-columns: max-content minmax(0, 1fr);
      gap: 0.45rem 0.8rem;
    }

    .work-mode-nav__trail {
      min-width: 0;
    }

    .work-mode-nav__modes {
      grid-column: 1 / -1;
      justify-self: end;
    }
  }
</style>
