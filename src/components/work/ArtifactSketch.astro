---
import { Image } from 'astro:assets';

import chineseBeeIcon from '../../assets/software-showcases/chinesebe_icon.png';
import chineseBeeShowcase from '../../assets/software-showcases/chinesebe_showcase.png';
import foodDeliveryShowcase from '../../assets/software-showcases/food_app_delivery_showcase.png';
import discoursesCover from '../../assets/games/discourses/cover.png';
import discoursesScene from '../../assets/games/discourses/winter-scene.jpeg';
import santaCity from '../../assets/games/santa/city.png';
import santaMountains from '../../assets/games/santa/mountains.png';
import santaSky from '../../assets/games/santa/sky-texture.png';
import santaSleigh from '../../assets/games/santa/sleigh-with-elf.png';

interface Props {
  category: 'software' | 'games';
  slug: string;
}

const { category, slug } = Astro.props;

const softwareFlows: Record<string, { note: string; steps: string[] }> = {
  'flutter-product': {
    note: 'one incomplete need, carried across the whole product',
    steps: ['product need', 'interaction decisions', 'working application'],
  },
  'chinese-bee': {
    note: 'several surfaces, one learning capability',
    steps: ['Telegram experience', 'API + vocabulary', 'handwriting practice'],
  },
  'receipt-processing': {
    note: 'a simpler path hidden inside the input',
    steps: ['PDF with text', 'direct extraction', 'about 600–650 ms'],
  },
  'ordering-platform': {
    note: 'state crossing service boundaries',
    steps: ['order', 'payment + expiration', 'webhook delivery'],
  },
};

const softwareFlow = softwareFlows[slug];
const hasSoftwareShowcase = slug === 'flutter-product' || slug === 'chinese-bee';
---

<div
  class:list={['artifact-sketch', `artifact-sketch--${category}`, `artifact-sketch--${slug}`]}
  aria-hidden={hasSoftwareShowcase ? undefined : 'true'}
>
  {
    slug === 'flutter-product' && (
      <div class="artifact-sketch__software-showcase artifact-sketch__software-showcase--food">
        <Image
          src={foodDeliveryShowcase}
          alt="Six screens from the food-ordering application, including browsing, basket, checkout, orders, address selection, and delivery tracking."
          widths={[520, 760, 1050]}
          sizes="(max-width: 700px) 90vw, 42vw"
        />
      </div>
    )
  }

  {
    slug === 'chinese-bee' && (
      <div class="artifact-sketch__software-showcase artifact-sketch__software-showcase--bee">
        <Image
          class="artifact-sketch__bee-screens"
          src={chineseBeeShowcase}
          alt="Chinese Bee screens showing Telegram learning conversations, quizzes, handwriting practice, and recognition feedback."
          widths={[520, 760, 1100]}
          sizes="(max-width: 700px) 90vw, 42vw"
        />
        <Image
          class="artifact-sketch__bee-icon"
          src={chineseBeeIcon}
          alt="Chinese Bee mascot."
          width={180}
        />
      </div>
    )
  }

  {
    category === 'software' && softwareFlow && !hasSoftwareShowcase && (
      <div class="artifact-sketch__trace">
        <p>{softwareFlow.note}</p>
        <ol>
          {softwareFlow.steps.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    )
  }

  {
    slug === 'discourses-by-campfire' && (
      <div class="artifact-sketch__discourses">
        <Image class="artifact-sketch__scene" src={discoursesScene} alt="" width={720} />
        <Image class="artifact-sketch__cover" src={discoursesCover} alt="" width={390} />
        <span>cold forest / warm fire</span>
      </div>
    )
  }

  {
    slug === 'santa-foundation' && (
      <div class="artifact-sketch__santa">
        <Image class="artifact-sketch__santa-sky" src={santaSky} alt="" width={640} />
        <Image class="artifact-sketch__santa-mountains" src={santaMountains} alt="" width={640} />
        <Image class="artifact-sketch__santa-city" src={santaCity} alt="" width={640} />
        <Image class="artifact-sketch__santa-sleigh" src={santaSleigh} alt="" width={192} />
        <span>feedback → mechanic changes</span>
      </div>
    )
  }

  {
    slug === 'card-system-study' && (
      <div class="artifact-sketch__cards">
        <span>input</span><span>catalyst</span><span>mutation</span><span>effect</span>
      </div>
    )
  }

  {
    slug === 'snake-raylib' && (
      <div class="artifact-sketch__small-game artifact-sketch__small-game--snake">
        <span class="artifact-sketch__snake">● ● ● ●</span>
        <span>Go + raylib</span>
      </div>
    )
  }

  {
    slug === 'tic-tac-toe-opengl' && (
      <div class="artifact-sketch__small-game artifact-sketch__small-game--grid">
        <span>×</span><span>○</span><span>×</span><span>○</span><span>×</span><span>○</span><span>×</span><span>○</span><span>×</span>
      </div>
    )
  }
</div>

<style>
  .artifact-sketch {
    width: 100%;
  }

  .artifact-sketch__software-showcase {
    position: relative;
    width: 100%;
  }

  .artifact-sketch__software-showcase :global(img) {
    display: block;
    width: 100%;
    height: auto;
  }

  .artifact-sketch__software-showcase--food {
    overflow: hidden;
    border-top: 0.14rem solid rgba(243, 239, 228, 0.58);
    border-right: 0.08rem solid rgba(243, 239, 228, 0.25);
    border-bottom: 0.12rem solid var(--work-accent);
    border-left: 0.16rem solid rgba(243, 239, 228, 0.4);
    box-shadow: 0.35rem 0.55rem 0 rgba(7, 7, 6, 0.18);
    transform: rotate(-1.2deg);
  }

  .artifact-sketch__software-showcase--bee {
    padding: 0.35rem;
    transform: rotate(1.2deg);
  }

  .artifact-sketch__bee-screens {
    border-top: 0.1rem solid rgba(243, 239, 228, 0.3);
    border-right: 0.16rem solid rgba(243, 239, 228, 0.55);
    border-bottom: 0.12rem solid var(--work-accent);
    border-left: 0.08rem solid rgba(243, 239, 228, 0.24);
    box-shadow: 0.4rem 0.5rem 0 rgba(7, 7, 6, 0.2);
  }

  .artifact-sketch__software-showcase .artifact-sketch__bee-icon {
    position: absolute;
    right: -1.2rem;
    bottom: -1.6rem;
    width: clamp(5.5rem, 24%, 9rem);
    border: 0.14rem solid rgba(243, 239, 228, 0.5);
    border-radius: 50%;
    box-shadow: 0 0 0 0.35rem rgba(23, 23, 22, 0.72);
    transform: rotate(-7deg);
  }

  .artifact-sketch__trace {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border-top: 0.12rem solid var(--work-accent);
    border-left: 0.1rem solid rgba(243, 239, 228, 0.32);
    transform: rotate(-2deg);
  }

  .artifact-sketch--chinese-bee .artifact-sketch__trace,
  .artifact-sketch--ordering-platform .artifact-sketch__trace {
    transform: rotate(2deg);
  }

  .artifact-sketch__trace p {
    max-width: 26ch;
    color: rgba(243, 239, 228, 0.7);
    line-height: 1.3;
  }

  .artifact-sketch__trace ol {
    display: grid;
    gap: 1.6rem;
    padding: 0;
    counter-reset: trace-step;
    list-style: none;
  }

  .artifact-sketch__trace li {
    position: relative;
    min-height: 2.75rem;
    padding: 0.65rem 0.7rem 0.55rem 2.4rem;
    border-top: 0.1rem solid rgba(243, 239, 228, 0.4);
    border-bottom: 0.08rem solid rgba(243, 239, 228, 0.18);
    counter-increment: trace-step;
    line-height: 1.25;
  }

  .artifact-sketch__trace li::before {
    position: absolute;
    top: 0.45rem;
    left: 0.65rem;
    content: counter(trace-step);
  }

  .artifact-sketch__trace li:not(:last-child)::after {
    position: absolute;
    z-index: -1;
    bottom: -1.7rem;
    left: 50%;
    width: 0.1rem;
    height: 1.7rem;
    background: var(--work-accent);
    content: '';
    transform: rotate(4deg);
  }

  .artifact-sketch__discourses {
    position: relative;
    min-height: clamp(15rem, 33vw, 24rem);
  }

  .artifact-sketch__discourses :global(img) {
    position: absolute;
    display: block;
    height: auto;
    object-fit: cover;
    filter: saturate(0.82) contrast(0.96);
    box-shadow: 0.45rem 0.65rem 0 rgba(7, 7, 6, 0.22);
  }

  .artifact-sketch__scene {
    inset: 0 auto auto 0;
    width: 88%;
    aspect-ratio: 16 / 9;
    transform: rotate(-3deg);
  }

  .artifact-sketch__cover {
    right: 0;
    bottom: 0;
    width: 49%;
    aspect-ratio: 1.26;
    transform: rotate(4deg);
  }

  .artifact-sketch__discourses span,
  .artifact-sketch__santa span {
    position: absolute;
    z-index: 3;
    right: 2%;
    bottom: -1.2rem;
    max-width: 18ch;
    padding: 0.45rem 0.15rem;
    color: var(--color-field-ink);
    line-height: 1.2;
    text-shadow: 0.08rem 0.1rem 0 var(--color-field);
    transform: rotate(-2deg);
  }

  .artifact-sketch__santa {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border-top: 0.18rem solid rgba(243, 239, 228, 0.54);
    border-right: 0.08rem solid rgba(243, 239, 228, 0.25);
    border-bottom: 0.16rem solid var(--work-accent);
    border-left: 0.12rem solid rgba(243, 239, 228, 0.36);
    background: #7189a8;
    box-shadow: 0.45rem 0.65rem 0 rgba(7, 7, 6, 0.22);
    image-rendering: pixelated;
    transform: rotate(2deg);
  }

  .artifact-sketch__santa :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .artifact-sketch__santa .artifact-sketch__santa-sleigh {
    z-index: 3;
    top: 27%;
    right: 8%;
    bottom: auto;
    left: auto;
    width: 34%;
    height: auto;
    object-fit: contain;
  }

  .artifact-sketch__santa span {
    right: 0.4rem;
    bottom: 0.25rem;
    color: var(--color-field-ink);
    image-rendering: auto;
  }

  .artifact-sketch__cards {
    display: flex;
    min-height: 11rem;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .artifact-sketch__cards span {
    display: grid;
    width: 5.3rem;
    aspect-ratio: 0.72;
    place-items: center;
    margin-left: -1rem;
    border: 0.1rem solid rgba(243, 239, 228, 0.6);
    background: var(--color-field);
    font-size: 0.85rem;
    text-align: center;
    transform: rotate(-8deg);
  }

  .artifact-sketch__cards span:nth-child(2) {
    transform: translateY(-0.6rem) rotate(4deg);
  }

  .artifact-sketch__cards span:nth-child(3) {
    transform: translateY(0.5rem) rotate(-2deg);
  }

  .artifact-sketch__cards span:nth-child(4) {
    transform: rotate(8deg);
  }

  .artifact-sketch__small-game {
    display: grid;
    min-height: 8rem;
    place-items: center;
    gap: 0.5rem;
    padding: 1rem;
    border-top: 0.12rem dashed rgba(243, 239, 228, 0.5);
    border-bottom: 0.12rem dashed rgba(243, 239, 228, 0.25);
  }

  .artifact-sketch__snake {
    letter-spacing: -0.25em;
    transform: rotate(8deg);
  }

  .artifact-sketch__small-game--grid {
    grid-template-columns: repeat(3, 2rem);
    gap: 0;
    min-height: 7rem;
  }

  .artifact-sketch__small-game--grid span {
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    border-right: 0.08rem solid rgba(243, 239, 228, 0.48);
    border-bottom: 0.08rem solid rgba(243, 239, 228, 0.48);
  }

  .artifact-sketch__small-game--grid span:nth-child(3n) {
    border-right: 0;
  }

  .artifact-sketch__small-game--grid span:nth-last-child(-n + 3) {
    border-bottom: 0;
  }
</style>
