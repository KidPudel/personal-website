---
import { Image } from 'astro:assets';

import discoursesCover from '../../assets/games/discourses/cover.png';
import discoursesScene from '../../assets/games/discourses/winter-scene.jpeg';
import santaCity from '../../assets/games/santa/city.png';
import santaMountains from '../../assets/games/santa/mountains.png';
import santaSky from '../../assets/games/santa/sky-texture.png';
import santaSleigh from '../../assets/games/santa/sleigh-with-elf.png';

interface Props {
  category: 'software' | 'games';
  slug: string;
}

const { category, slug } = Astro.props;

const softwareFlows: Record<string, { note: string; steps: string[] }> = {
  'flutter-product': {
    note: 'one incomplete need, carried across the whole product',
    steps: ['product need', 'interaction decisions', 'working application'],
  },
  'chinese-bee': {
    note: 'several surfaces, one learning capability',
    steps: ['Telegram experience', 'API + vocabulary', 'handwriting practice'],
  },
  'receipt-processing': {
    note: 'a simpler path hidden inside the input',
    steps: ['PDF with text', 'direct extraction', 'about 600–650 ms'],
  },
  'ordering-platform': {
    note: 'state crossing service boundaries',
    steps: ['order', 'payment + expiration', 'webhook delivery'],
  },
};

const softwareFlow = softwareFlows[slug];
---

<div class:list={['artifact-sketch', `artifact-sketch--${category}`, `artifact-sketch--${slug}`]} aria-hidden="true">
  {
    category === 'software' && softwareFlow && (
      <div class="artifact-sketch__trace">
        <p>{softwareFlow.note}</p>
        <ol>
          {softwareFlow.steps.map((step) => <li>{step}</li>)}
        </ol>
      </div>
    )
  }

  {
    slug === 'discourses-by-campfire' && (
      <div class="artifact-sketch__discourses">
        <Image class="artifact-sketch__scene" src={discoursesScene} alt="" width={720} />
        <Image class="artifact-sketch__cover" src={discoursesCover} alt="" width={390} />
        <span>cold forest / warm fire</span>
      </div>
    )
  }

  {
    slug === 'santa-foundation' && (
      <div class="artifact-sketch__santa">
        <Image class="artifact-sketch__santa-sky" src={santaSky} alt="" width={640} />
        <Image class="artifact-sketch__santa-mountains" src={santaMountains} alt="" width={640} />
        <Image class="artifact-sketch__santa-city" src={santaCity} alt="" width={640} />
        <Image class="artifact-sketch__santa-sleigh" src={santaSleigh} alt="" width={192} />
        <span>feedback → mechanic changes</span>
      </div>
    )
  }

  {
    slug === 'card-system-study' && (
      <div class="artifact-sketch__cards">
        <span>input</span><span>catalyst</span><span>mutation</span><span>effect</span>
      </div>
    )
  }

  {
    slug === 'snake-raylib' && (
      <div class="artifact-sketch__small-game artifact-sketch__small-game--snake">
        <span class="artifact-sketch__snake">● ● ● ●</span>
        <span>Go + raylib</span>
      </div>
    )
  }

  {
    slug === 'tic-tac-toe-opengl' && (
      <div class="artifact-sketch__small-game artifact-sketch__small-game--grid">
        <span>×</span><span>○</span><span>×</span><span>○</span><span>×</span><span>○</span><span>×</span><span>○</span><span>×</span>
      </div>
    )
  }
</div>

<style>
  .artifact-sketch {
    width: 100%;
  }

  .artifact-sketch__trace {
    display: grid;
    gap: 1.5rem;
    padding: clamp(1.25rem, 3vw, 2rem);
    border: 0.12rem solid rgba(37, 79, 99, 0.45);
    background: rgba(225, 234, 224, 0.42);
    transform: rotate(-2deg);
  }

  .artifact-sketch--chinese-bee .artifact-sketch__trace,
  .artifact-sketch--ordering-platform .artifact-sketch__trace {
    transform: rotate(2deg);
  }

  .artifact-sketch__trace p {
    max-width: 26ch;
    color: rgba(32, 32, 30, 0.76);
    line-height: 1.3;
  }

  .artifact-sketch__trace ol {
    display: grid;
    gap: 1.6rem;
    padding: 0;
    counter-reset: trace-step;
    list-style: none;
  }

  .artifact-sketch__trace li {
    position: relative;
    min-height: 2.75rem;
    padding: 0.65rem 0.7rem 0.55rem 2.4rem;
    border: 0.1rem solid rgba(32, 32, 30, 0.52);
    background: rgba(247, 239, 218, 0.7);
    counter-increment: trace-step;
    line-height: 1.25;
  }

  .artifact-sketch__trace li::before {
    position: absolute;
    top: 0.45rem;
    left: 0.65rem;
    content: counter(trace-step);
  }

  .artifact-sketch__trace li:not(:last-child)::after {
    position: absolute;
    z-index: -1;
    bottom: -1.7rem;
    left: 50%;
    width: 0.1rem;
    height: 1.7rem;
    background: rgba(32, 32, 30, 0.55);
    content: '';
    transform: rotate(4deg);
  }

  .artifact-sketch__discourses {
    position: relative;
    min-height: clamp(15rem, 33vw, 24rem);
  }

  .artifact-sketch__discourses :global(img) {
    position: absolute;
    display: block;
    height: auto;
    object-fit: cover;
    filter: saturate(0.82) contrast(0.96);
    box-shadow: 0 0.65rem 1rem rgba(32, 32, 30, 0.17);
  }

  .artifact-sketch__scene {
    inset: 0 auto auto 0;
    width: 88%;
    aspect-ratio: 16 / 9;
    transform: rotate(-3deg);
  }

  .artifact-sketch__cover {
    right: 0;
    bottom: 0;
    width: 49%;
    aspect-ratio: 1.26;
    transform: rotate(4deg);
  }

  .artifact-sketch__discourses span,
  .artifact-sketch__santa span {
    position: absolute;
    z-index: 3;
    right: 2%;
    bottom: -1.2rem;
    max-width: 18ch;
    padding: 0.45rem 0.6rem;
    background: var(--color-paper);
    line-height: 1.2;
    transform: rotate(-2deg);
  }

  .artifact-sketch__santa {
    position: relative;
    aspect-ratio: 16 / 9;
    overflow: hidden;
    border: 0.25rem solid rgba(32, 32, 30, 0.72);
    background: #7189a8;
    box-shadow: 0 0.65rem 1rem rgba(32, 32, 30, 0.17);
    image-rendering: pixelated;
    transform: rotate(2deg);
  }

  .artifact-sketch__santa :global(img) {
    position: absolute;
    inset: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    image-rendering: pixelated;
  }

  .artifact-sketch__santa .artifact-sketch__santa-sleigh {
    z-index: 3;
    top: 27%;
    right: 8%;
    bottom: auto;
    left: auto;
    width: 34%;
    height: auto;
    object-fit: contain;
  }

  .artifact-sketch__santa span {
    right: 0.4rem;
    bottom: 0.25rem;
    color: var(--color-ink);
    image-rendering: auto;
  }

  .artifact-sketch__cards {
    display: flex;
    min-height: 11rem;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }

  .artifact-sketch__cards span {
    display: grid;
    width: 5.3rem;
    aspect-ratio: 0.72;
    place-items: center;
    margin-left: -1rem;
    border: 0.1rem solid rgba(32, 32, 30, 0.65);
    background: rgba(242, 232, 207, 0.9);
    font-size: 0.85rem;
    text-align: center;
    transform: rotate(-8deg);
  }

  .artifact-sketch__cards span:nth-child(2) {
    transform: translateY(-0.6rem) rotate(4deg);
  }

  .artifact-sketch__cards span:nth-child(3) {
    transform: translateY(0.5rem) rotate(-2deg);
  }

  .artifact-sketch__cards span:nth-child(4) {
    transform: rotate(8deg);
  }

  .artifact-sketch__small-game {
    display: grid;
    min-height: 8rem;
    place-items: center;
    gap: 0.5rem;
    padding: 1rem;
    border: 0.12rem dashed rgba(32, 32, 30, 0.45);
  }

  .artifact-sketch__snake {
    letter-spacing: -0.25em;
    transform: rotate(8deg);
  }

  .artifact-sketch__small-game--grid {
    grid-template-columns: repeat(3, 2rem);
    gap: 0;
    min-height: 7rem;
  }

  .artifact-sketch__small-game--grid span {
    display: grid;
    aspect-ratio: 1;
    place-items: center;
    border-right: 0.08rem solid rgba(32, 32, 30, 0.55);
    border-bottom: 0.08rem solid rgba(32, 32, 30, 0.55);
  }

  .artifact-sketch__small-game--grid span:nth-child(3n) {
    border-right: 0;
  }

  .artifact-sketch__small-game--grid span:nth-last-child(-n + 3) {
    border-bottom: 0;
  }
</style>
