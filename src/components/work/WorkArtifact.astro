---
interface Props {
  title: string;
  summary: string;
  prominence: 'featured' | 'supporting' | 'trajectory';
  status: 'complete' | 'ongoing' | 'unfinished' | 'early-work';
  capabilities?: string[];
  result?: string;
  meta?: string;
  externalUrl?: string;
}

const { title, summary, prominence, status, capabilities = [], result, meta, externalUrl } = Astro.props;
const statusLabel = {
  complete: 'complete',
  ongoing: 'ongoing',
  unfinished: 'unfinished',
  'early-work': 'early work',
}[status];
---

<article class:list={['work-artifact', `work-artifact--${prominence}`, `work-artifact--${status}`]}>
  <div class="work-artifact__sketch">
    <slot name="sketch" />
  </div>
  <div class="work-artifact__copy">
    <p class="work-artifact__status">{statusLabel}{meta ? ` · ${meta}` : ''}</p>
    <h2>{title}</h2>
    <p class="work-artifact__summary">{summary}</p>
    {result && <p class="work-artifact__result">{result}</p>}
    {
      capabilities.length > 0 && (
        <ul class="work-artifact__capabilities" aria-label="Capabilities and tools">
          {capabilities.map((capability) => <li>{capability}</li>)}
        </ul>
      )
    }
    {
      externalUrl && (
        <a class="work-artifact__open" href={externalUrl} rel="noreferrer">
          visit the project <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .work-artifact {
    position: relative;
    display: grid;
    grid-template-columns: minmax(14rem, 0.82fr) minmax(0, 1.18fr);
    align-items: center;
    gap: clamp(1.75rem, 5vw, 4.5rem);
    padding: clamp(1.75rem, 4vw, 3.75rem);
    background: rgba(247, 239, 218, 0.74);
    box-shadow: 0 0.45rem 1rem rgba(32, 32, 30, 0.08);
    clip-path: polygon(0.5% 1.5%, 97.5% 0, 100% 95%, 3% 100%, 0 12%);
  }

  .work-artifact:nth-child(even) {
    grid-template-columns: minmax(0, 1.18fr) minmax(14rem, 0.82fr);
    clip-path: polygon(2% 0, 99.5% 2%, 98% 100%, 0 96%);
  }

  .work-artifact:nth-child(even) .work-artifact__sketch {
    grid-column: 2;
  }

  .work-artifact:nth-child(even) .work-artifact__copy {
    grid-row: 1;
    grid-column: 1;
  }

  .work-artifact--supporting,
  .work-artifact--trajectory {
    grid-template-columns: minmax(8rem, 0.45fr) minmax(0, 1.55fr);
    gap: clamp(1rem, 3vw, 2.5rem);
    padding: clamp(1.25rem, 3vw, 2.25rem);
  }

  .work-artifact--trajectory {
    background: rgba(247, 239, 218, 0.52);
    box-shadow: none;
  }

  .work-artifact--unfinished {
    border: 0.12rem dashed rgba(32, 32, 30, 0.38);
  }

  .work-artifact__copy {
    display: grid;
    gap: 0.85rem;
  }

  .work-artifact__sketch {
    width: 100%;
  }

  .work-artifact__status {
    width: fit-content;
    padding: 0.1rem 0.45rem;
    border: 1px solid rgba(32, 32, 30, 0.45);
    font-size: 0.85rem;
    line-height: 1.3;
    transform: rotate(-1.5deg);
  }

  .work-artifact--unfinished .work-artifact__status,
  .work-artifact--early-work .work-artifact__status {
    border-style: dashed;
  }

  .work-artifact h2 {
    max-width: 21ch;
    font-size: clamp(1.65rem, 3vw, 2.65rem);
    font-weight: 400;
    line-height: 1.08;
  }

  .work-artifact__open {
    color: var(--color-ink);
    text-decoration-thickness: 0.09rem;
    text-underline-offset: 0.18em;
  }

  .work-artifact__summary {
    max-width: 54ch;
    font-size: clamp(1.05rem, 1.6vw, 1.2rem);
    line-height: 1.55;
  }

  .work-artifact__result {
    max-width: 28ch;
    font-family: var(--font-distinctive);
    font-size: clamp(1.55rem, 2.6vw, 2.35rem);
    line-height: 1.05;
    transform: rotate(-1deg);
  }

  .work-artifact__capabilities {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.75rem;
    padding: 0;
    list-style: none;
    color: rgba(32, 32, 30, 0.76);
    font-size: 0.92rem;
  }

  .work-artifact__capabilities li::before {
    content: '# ';
  }

  .work-artifact__open {
    width: fit-content;
    min-height: 2.75rem;
    padding-block: 0.55rem;
  }

  @media (max-width: 44rem) {
    .work-artifact,
    .work-artifact:nth-child(even),
    .work-artifact--supporting,
    .work-artifact--trajectory {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.5rem;
    }

    .work-artifact:nth-child(even) .work-artifact__sketch,
    .work-artifact:nth-child(even) .work-artifact__copy {
      grid-row: auto;
      grid-column: 1;
    }

    .work-artifact__sketch {
      max-width: 26rem;
      margin-inline: auto;
    }
  }
</style>
