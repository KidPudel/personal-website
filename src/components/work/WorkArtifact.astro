---
interface Props {
  title: string;
  prominence: 'featured' | 'supporting' | 'trajectory';
  status: 'complete' | 'ongoing' | 'unfinished' | 'early-work';
  learnings?: string[];
  result?: string;
  externalUrl?: string;
}

const { title, prominence, status, learnings = [], result, externalUrl } = Astro.props;
const statusLabel = {
  complete: 'complete',
  ongoing: 'still changing',
  unfinished: 'unfinished',
  'early-work': 'early experiment',
}[status];
---

<article class:list={['work-artifact', `work-artifact--${prominence}`, `work-artifact--${status}`]}>
  <svg class="work-artifact__trace" viewBox="0 0 1000 560" preserveAspectRatio="none" aria-hidden="true">
    <path class="work-artifact__trace-long" d="M34 92 C168 47 305 84 454 54 C581 28 699 65 813 43" />
    <path class="work-artifact__trace-short" d="M532 276 C490 252 458 247 411 260" />
    <path class="work-artifact__trace-arrow" d="M424 247 L411 260 L429 267" />
  </svg>

  <div class="work-artifact__sketch">
    <slot name="sketch" />
  </div>

  <div class="work-artifact__copy">
    <h3>{title}</h3>
    {result && <p class="work-artifact__result">{result}</p>}
    {status !== 'complete' && <p class="work-artifact__status">{statusLabel}</p>}
    {
      learnings.length > 0 && (
        <aside class="work-artifact__learnings" aria-label="What I've learned">
          <p>What I've learned</p>
          <ul>
            {learnings.map((learning) => <li>{learning}</li>)}
          </ul>
        </aside>
      )
    }
    {
      externalUrl && (
        <a class="work-artifact__open" href={externalUrl} rel="noreferrer">
          visit the project <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>
</article>

<style>
  .work-artifact {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: clamp(31rem, 48vw, 39rem);
    grid-template-columns: minmax(15rem, 1.05fr) minmax(0, 0.95fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5.5rem);
    padding: clamp(6rem, 9vw, 7.5rem) clamp(1rem, 4vw, 3.5rem) clamp(6.5rem, 10vw, 8rem);
  }

  .work-artifact:nth-child(even) {
    grid-template-columns: minmax(0, 0.95fr) minmax(15rem, 1.05fr);
  }

  .work-artifact:nth-child(even) .work-artifact__sketch {
    grid-column: 2;
  }

  .work-artifact:nth-child(even) .work-artifact__copy {
    grid-row: 1;
    grid-column: 1;
  }

  .work-artifact__trace {
    position: absolute;
    z-index: -1;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .work-artifact__trace path {
    fill: none;
    stroke: rgba(243, 239, 228, 0.32);
    stroke-linecap: round;
    stroke-linejoin: round;
    stroke-width: 1.35;
    vector-effect: non-scaling-stroke;
  }

  .work-artifact__trace-long {
    stroke: color-mix(in srgb, var(--work-accent) 55%, rgba(243, 239, 228, 0.34)) !important;
  }

  .work-artifact:nth-child(even) .work-artifact__trace {
    transform: scaleX(-1) rotate(-0.5deg);
  }

  .work-artifact--trajectory {
    min-height: 25rem;
    grid-template-columns: minmax(7rem, 0.65fr) minmax(0, 1.35fr);
    gap: clamp(1.25rem, 3vw, 2.5rem);
    padding: 5rem clamp(1rem, 3vw, 2rem) 6rem;
  }

  .work-artifact--trajectory .work-artifact__trace-long {
    stroke-dasharray: 7 8 2 6;
  }

  .work-artifact__copy {
    display: grid;
    gap: 1.25rem;
  }

  .work-artifact__sketch {
    width: 100%;
  }

  .work-artifact h3 {
    max-width: 20ch;
    font-family: var(--font-distinctive);
    font-size: clamp(1.8rem, 3.2vw, 2.9rem);
    font-weight: 400;
    line-height: 1.08;
    transform: rotate(-0.8deg);
  }

  .work-artifact--trajectory h3 {
    max-width: none;
    font-family: var(--font-reading);
    font-size: clamp(1.45rem, 2.35vw, 2rem);
    text-wrap: balance;
  }

  .work-artifact__result {
    max-width: 25ch;
    color: var(--work-accent);
    font-family: var(--font-distinctive);
    font-size: clamp(1.55rem, 2.6vw, 2.35rem);
    line-height: 1.05;
    transform: rotate(-1deg);
  }

  .work-artifact__status {
    width: fit-content;
    color: rgba(243, 239, 228, 0.62);
    font-size: 0.95rem;
    font-style: italic;
    transform: rotate(-1deg);
  }

  .work-artifact__open {
    width: fit-content;
    min-height: 2.75rem;
    padding-block: 0.55rem;
    color: var(--color-field-ink);
    text-decoration-thickness: 0.09rem;
    text-underline-offset: 0.18em;
  }

  .work-artifact__learnings {
    display: grid;
    gap: 0.65rem;
    max-width: 22rem;
    margin-top: 0.35rem;
    padding: 0.85rem 0 0 1.15rem;
    border-left: 0.11rem solid color-mix(in srgb, var(--work-accent) 65%, transparent);
    transform: rotate(-0.4deg);
  }

  .work-artifact__learnings > p {
    color: var(--work-accent);
    font-size: 1rem;
  }

  .work-artifact__learnings ul {
    display: grid;
    gap: 0.35rem;
    padding: 0;
    list-style: none;
  }

  .work-artifact__learnings li {
    color: rgba(243, 239, 228, 0.7);
    font-size: 1.05rem;
    line-height: 1.45;
  }

  .work-artifact__learnings li::before {
    color: var(--work-accent);
    content: '·';
    margin-right: 0.55rem;
  }

  @media (max-width: 44rem) {
    .work-artifact,
    .work-artifact:nth-child(even),
    .work-artifact--trajectory {
      grid-template-columns: minmax(0, 1fr);
      gap: 1.75rem;
      min-height: 0;
      padding: 4.5rem 0.8rem 2rem 1rem;
    }

    .work-artifact:nth-child(even) .work-artifact__sketch,
    .work-artifact:nth-child(even) .work-artifact__copy {
      grid-row: auto;
      grid-column: 1;
    }

    .work-artifact__sketch {
      max-width: 26rem;
      margin-inline: auto;
    }

    .work-artifact__learnings {
      max-width: 19rem;
    }
  }
</style>
