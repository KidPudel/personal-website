---
import { sitePath } from '../../config/site';
import WorkModeNav from './WorkModeNav.astro';

interface Props {
  current: 'software' | 'games';
  title: string;
  summary: string;
  status: 'complete' | 'ongoing' | 'unfinished' | 'early-work';
  capabilities?: string[];
  result?: string;
  meta?: string;
  externalUrl?: string;
}

const { current, title, summary, status, capabilities = [], result, meta, externalUrl } = Astro.props;
const statusLabel = {
  complete: 'complete artifact',
  ongoing: 'ongoing work',
  unfinished: 'unfinished work',
  'early-work': 'early work',
}[status];
const indexHref = sitePath(`/work/${current}/`);
---

<article class:list={['project-evidence', `project-evidence--${status}`]}>
  <WorkModeNav current={current} />

  <a class="project-evidence__back" href={indexHref}>← all {current}</a>

  <header class="project-evidence__header">
    <div class="project-evidence__heading">
      <p class="project-evidence__status">{statusLabel}{meta ? ` · ${meta}` : ''}</p>
      <h1>{title}</h1>
      <p class="project-evidence__summary">{summary}</p>
    </div>
    <div class="project-evidence__sketch">
      <slot name="sketch" />
    </div>
  </header>

  <div class="project-evidence__record">
    {
      result && (
        <aside class="project-evidence__result" aria-label="Verified result">
          <span>verified result</span>
          <strong>{result}</strong>
        </aside>
      )
    }

    <div class="project-evidence__body">
      <slot />
    </div>

    {
      capabilities.length > 0 && (
        <aside class="project-evidence__capability-note" aria-labelledby="capability-note-title">
          <p id="capability-note-title">capabilities in this artifact</p>
          <ul>
            {capabilities.map((capability) => <li>{capability}</li>)}
          </ul>
        </aside>
      )
    }

    {
      status === 'unfinished' && (
        <p class="project-evidence__unfinished-note">
          This is kept here as unfinished work. It shows a real line of inquiry, including what did not hold together yet.
        </p>
      )
    }

    {
      externalUrl && (
        <a class="project-evidence__external" href={externalUrl} rel="noreferrer">
          open the public artifact <span aria-hidden="true">↗</span>
        </a>
      )
    }
  </div>

  <footer class="project-evidence__footer">
    <a href={indexHref}>return to all {current}</a>
  </footer>
</article>

<style>
  .project-evidence {
    display: grid;
    gap: clamp(2.5rem, 6vw, 5rem);
  }

  .project-evidence__back,
  .project-evidence__footer a,
  .project-evidence__external {
    width: fit-content;
    min-height: 2.75rem;
    padding-block: 0.55rem;
    color: var(--color-ink);
    text-underline-offset: 0.2em;
  }

  .project-evidence__back {
    margin-top: -3rem;
  }

  .project-evidence__header {
    display: grid;
    grid-template-columns: minmax(0, 1.08fr) minmax(16rem, 0.92fr);
    align-items: center;
    gap: clamp(2rem, 6vw, 5.5rem);
    min-height: 30rem;
  }

  .project-evidence__heading {
    display: grid;
    gap: 1.25rem;
  }

  .project-evidence__status {
    width: fit-content;
    padding: 0.15rem 0.55rem;
    border: 0.1rem solid rgba(32, 32, 30, 0.46);
    line-height: 1.3;
    transform: rotate(-1.5deg);
  }

  .project-evidence--unfinished .project-evidence__status,
  .project-evidence--early-work .project-evidence__status {
    border-style: dashed;
  }

  .project-evidence h1 {
    max-width: 17ch;
    font-family: var(--font-distinctive);
    font-size: clamp(2.65rem, 5.7vw, 5.4rem);
    font-weight: 400;
    line-height: 0.98;
  }

  .project-evidence__summary {
    max-width: 53ch;
    font-size: clamp(1.08rem, 1.75vw, 1.28rem);
    line-height: 1.55;
  }

  .project-evidence__sketch {
    position: relative;
    z-index: 1;
    width: 100%;
  }

  .project-evidence__sketch::before {
    position: absolute;
    z-index: -1;
    inset: -1.2rem 0.8rem 0.8rem -1.2rem;
    border: 0.1rem solid rgba(54, 102, 122, 0.28);
    background: rgba(225, 234, 224, 0.2);
    content: '';
    transform: rotate(4deg);
  }

  .project-evidence__record {
    display: grid;
    grid-template-columns: minmax(0, 1.25fr) minmax(13rem, 0.75fr);
    align-items: start;
    gap: clamp(2.5rem, 7vw, 6rem);
  }

  .project-evidence__body {
    display: grid;
    gap: 1.35rem;
    max-width: 59ch;
    font-size: clamp(1.08rem, 1.7vw, 1.22rem);
    line-height: 1.65;
  }

  .project-evidence__body :global(p) {
    margin: 0;
  }

  .project-evidence__result {
    grid-column: 1 / -1;
    display: grid;
    gap: 0.65rem;
    width: min(100%, 44rem);
    justify-self: center;
    padding: clamp(1.5rem, 4vw, 2.75rem);
    border: 0.12rem solid rgba(32, 32, 30, 0.48);
    background: rgba(247, 239, 218, 0.68);
    text-align: center;
    transform: rotate(-1deg);
  }

  .project-evidence__result span {
    font-size: 0.92rem;
  }

  .project-evidence__result strong {
    font-family: var(--font-distinctive);
    font-size: clamp(2rem, 4.7vw, 4.25rem);
    font-weight: 400;
    line-height: 1;
  }

  .project-evidence__capability-note {
    padding: 1.4rem;
    border: 0.11rem dashed rgba(32, 32, 30, 0.46);
    background: rgba(247, 239, 218, 0.52);
    transform: rotate(1.5deg);
  }

  .project-evidence__capability-note p {
    margin-bottom: 0.8rem;
  }

  .project-evidence__capability-note ul {
    display: grid;
    gap: 0.35rem;
    padding: 0;
    list-style: none;
  }

  .project-evidence__capability-note li::before {
    content: '× ';
  }

  .project-evidence__unfinished-note {
    grid-column: 1 / -1;
    max-width: 50ch;
    padding: 1rem 1.25rem;
    border-left: 0.16rem solid rgba(32, 32, 30, 0.62);
    font-size: 1.05rem;
  }

  .project-evidence__external {
    grid-column: 2;
    font-size: 1.1rem;
  }

  .project-evidence__footer {
    padding-top: 1.25rem;
    border-top: 0.1rem solid rgba(32, 32, 30, 0.25);
  }

  @media (max-width: 48rem) {
    .project-evidence__header,
    .project-evidence__record {
      grid-template-columns: minmax(0, 1fr);
    }

    .project-evidence__header {
      min-height: auto;
    }

    .project-evidence__external {
      grid-column: 1;
    }
  }
</style>
