---
import type { CollectionEntry } from 'astro:content';

import { sitePath } from '../../config/site';

interface Props {
  entry: CollectionEntry<'writing'>;
  index: number;
}

const { entry, index } = Astro.props;
const isLocal = !entry.data.draft;
const href = isLocal ? sitePath(`/blog/${entry.id}/`) : entry.data.canonicalUrl;
const publishedAt = entry.data.publishedAt?.toLocaleDateString('en', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<li class="writing-entry">
  <article>
    <span class="writing-entry__number" aria-hidden="true">{String(index).padStart(2, '0')}</span>
    <div class="writing-entry__copy">
      <div class="writing-entry__meta">
        {publishedAt && <time datetime={entry.data.publishedAt?.toISOString()}>{publishedAt}</time>}
        {!isLocal && href && <span>Published on Medium</span>}
      </div>

      <h2>
        {
          href ? (
            <a href={href}>
              {entry.data.title}
              {!isLocal && <span class="writing-entry__external" aria-hidden="true">↗</span>}
            </a>
          ) : (
            entry.data.title
          )
        }
      </h2>
      <p>{entry.data.summary}</p>
    </div>
  </article>
</li>

<style>
  .writing-entry {
    position: relative;
    padding-block: clamp(1.8rem, 4vw, 3.2rem);
  }

  .writing-entry::after {
    position: absolute;
    right: 2%;
    bottom: 0;
    left: 7%;
    height: 0.12rem;
    background: rgba(243, 239, 228, 0.48);
    clip-path: polygon(0 41%, 18% 19%, 42% 55%, 63% 28%, 82% 64%, 100% 36%, 100% 100%, 0 100%);
    content: '';
    transform: rotate(-0.15deg);
  }

  article {
    display: grid;
    grid-template-columns: 3.5rem minmax(0, 1fr);
    gap: clamp(1rem, 3vw, 2.5rem);
    align-items: start;
  }

  .writing-entry__number {
    padding-top: 0.35rem;
    color: rgba(243, 239, 228, 0.46);
    font-family: var(--font-distinctive);
    font-size: 1rem;
    transform: rotate(-7deg);
  }

  .writing-entry__copy {
    display: grid;
    gap: 0.65rem;
    max-width: 47rem;
  }

  .writing-entry__meta {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 1rem;
    min-height: 1.3rem;
    color: rgba(243, 239, 228, 0.58);
    font-size: 0.82rem;
  }

  h2 {
    max-width: 19ch;
    font-family: var(--font-distinctive);
    font-size: clamp(2rem, 4.2vw, 3.6rem);
    font-weight: 400;
    line-height: 1.04;
  }

  h2 a {
    display: inline;
    color: inherit;
    text-decoration-color: rgba(243, 239, 228, 0.5);
    text-decoration-thickness: 0.11rem;
    text-underline-offset: 0.16em;
  }

  h2 a:hover {
    text-decoration-color: currentColor;
  }

  .writing-entry__external {
    display: inline-block;
    margin-left: 0.25em;
    color: rgba(243, 239, 228, 0.58);
    font-family: var(--font-reading);
    font-size: 0.48em;
    transform: translateY(-0.75em) rotate(5deg);
  }

  .writing-entry__copy > p {
    max-width: 60ch;
    color: rgba(243, 239, 228, 0.82);
    font-size: clamp(1rem, 1.7vw, 1.18rem);
    line-height: 1.65;
  }

  @media (max-width: 36rem) {
    article {
      grid-template-columns: 2rem minmax(0, 1fr);
      gap: 0.7rem;
    }

    .writing-entry__number {
      font-size: 0.86rem;
    }

    h2 {
      font-size: clamp(2rem, 11vw, 2.85rem);
    }
  }
</style>
