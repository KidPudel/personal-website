---
import { publicLinks } from '../config/site';

const base = import.meta.env.BASE_URL;
---

<footer class="site-footer">
  <p>Made with care, a few crooked lines, and no database.</p>
  <nav aria-label="Footer navigation">
    <a class="draw-link" href={`${base}connect/`}>Connect</a>
    <a class="draw-link" href={publicLinks.github}>GitHub</a>
    <a class="draw-link" href={publicLinks.itch}>itch.io</a>
    <a class="draw-link" href={publicLinks.linkedin}>LinkedIn</a>
    <a class="draw-link" href={publicLinks.x}>X</a>
  </nav>
</footer>
