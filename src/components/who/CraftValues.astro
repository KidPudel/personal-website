---
const values = [
  {
    words: ['experience', 'behaviour', 'capability'],
    before: 'Fulfil a real wish for ',
    after: '.',
    boxPath: 'M4.6 5.5 C9.2 4.6 16.1 5 21.6 4.2 C21.8 9.1 22.5 15.5 21.4 21.8 C16.3 21.2 9.2 22.4 4 21.5 C4.5 15.6 3.4 10.4 4.7 4.6',
    tickPath: 'M5.8 13.3 C7.9 14.5 9.3 16.4 10.8 18.1 C13.8 13.8 17.2 9.4 21.1 6.7',
  },
  {
    words: ['impactful', 'empowering'],
    before: 'Create an ',
    after: ' interaction experience.',
    boxPath: 'M4.1 4.7 C9.6 4.9 15.8 3.7 22.1 4.8 C21.7 10.3 22.6 16.6 21.5 22.1 C16.1 21.3 10.3 22.6 4.4 21.2 C5 15.3 3.6 9.6 4.5 4',
    tickPath: 'M5.7 13 C7.6 14.1 9.2 16.2 10.6 17.6 C13.5 14.1 17.5 9 21.2 6.4',
  },
  {
    words: ['clear', 'honest'],
    before: 'Be ',
    after: ' with users or players.',
    boxPath: 'M4.5 5 C9 4 17.4 4.2 21.7 4.8 C22.3 9.5 21.6 16.1 22.3 21.4 C16.7 22 9.7 22.5 4.1 21.6 C4.7 16.8 3.5 10.1 4.3 4.2',
    tickPath: 'M5.6 13.5 C7.8 14.4 9.1 16.1 10.7 17.9 C13.3 14.5 17.7 9.1 21.4 6.5',
  },
] as const;

interface Props {
  completionId: string;
}

const { completionId } = Astro.props;
---

<craft-values
  class="craft-values"
  aria-label="What matters to me in the things I make"
  data-completion-id={completionId}
>
  <div class="craft-values__heading">
    <p>three notes for the things I make</p>
    <span aria-hidden="true">tap a changing word</span>
  </div>

  <ol role="list">
    {values.map((value, index) => (
      <li>
        <input
          class="craft-values__input"
          type="checkbox"
          id={`craft-value-${index + 1}`}
          aria-label={`Mark value ${index + 1} as checked`}
        />
        <label class="craft-values__check-control" for={`craft-value-${index + 1}`}>
          <span class="craft-values__check" aria-hidden="true">
            <svg class="craft-values__check-svg" viewBox="0 0 26 26" focusable="false">
              <path class="craft-values__outline" d={value.boxPath}></path>
              <path class="craft-values__tick" d={value.tickPath} pathLength="100"></path>
            </svg>
          </span>
        </label>
        <p>
          <span class="craft-values__copy">
            {value.before}
            <button
              type="button"
              class="word-cycle"
              data-word-cycle
              data-value-number={index + 1}
              aria-label={`${value.words.join(', ')}. Word choices.`}
              disabled
            >
              {value.words.map((word, wordIndex) => (
                <span
                  class="word-cycle__option"
                  data-word-option
                  data-active={wordIndex === 0 ? '' : undefined}
                >
                  {word}
                </span>
              ))}
            </button>{value.after}
          </span>
          <span class="craft-values__strike" aria-hidden="true"></span>
        </p>
      </li>
    ))}
  </ol>

</craft-values>

<script>
  class CraftValues extends HTMLElement {
    connectedCallback() {
      if (this.dataset.enhanced) return;

      const controls = Array.from(this.querySelectorAll<HTMLButtonElement>('[data-word-cycle]'));
      const checkboxes = Array.from(this.querySelectorAll<HTMLInputElement>('.craft-values__input'));
      const completion = document.getElementById(this.dataset.completionId ?? '');
      if (!controls.length || !checkboxes.length || !completion) return;

      this.dataset.enhanced = 'true';

      controls.forEach((button) => {
        const options = Array.from(button.querySelectorAll<HTMLElement>('[data-word-option]'));
        let activeIndex = 0;

        const update = () => {
          options.forEach((option, index) => {
            const isActive = index === activeIndex;
            option.toggleAttribute('data-active', isActive);
            option.setAttribute('aria-hidden', String(!isActive));
          });

          const currentWord = options[activeIndex]?.textContent?.trim() ?? '';
          button.setAttribute('aria-label', `${currentWord}. Change this word.`);
        };

        button.disabled = false;
        button.addEventListener('click', () => {
          activeIndex = (activeIndex + 1) % options.length;
          update();
        });
        update();
      });

      let completionScrollTimer: number | undefined;

      const updateCompletion = () => {
        const complete = checkboxes.every((checkbox) => checkbox.checked);
        const wasComplete = this.hasAttribute('data-complete');
        completion.hidden = !complete;
        this.toggleAttribute('data-complete', complete);

        if (completionScrollTimer) {
          window.clearTimeout(completionScrollTimer);
          completionScrollTimer = undefined;
        }

        if (complete && !wasComplete) {
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          completionScrollTimer = window.setTimeout(() => {
            if (!this.hasAttribute('data-complete')) return;

            completion.scrollIntoView({
              behavior: reduceMotion ? 'auto' : 'smooth',
              block: 'nearest',
            });
          }, reduceMotion ? 0 : 360);
        }
      };

      checkboxes.forEach((checkbox) => checkbox.addEventListener('change', updateCompletion));
      updateCompletion();
    }
  }

  if (!customElements.get('craft-values')) {
    customElements.define('craft-values', CraftValues);
  }
</script>

<style>
  .craft-values {
    display: block;
    max-width: 47rem;
    margin: clamp(2.25rem, 4.5vw, 3.5rem) auto 0.15rem;
  }

  .craft-values__heading {
    display: flex;
    width: fit-content;
    max-width: 100%;
    flex-wrap: wrap;
    align-items: baseline;
    gap: 0.2rem 1.25rem;
    margin: 0 0 0.45rem 0.35rem;
    transform: rotate(-0.35deg);
  }

  .craft-values__heading p {
    font-size: clamp(1rem, 1.65vw, 1.2rem);
  }

  .craft-values__heading span {
    color: rgba(32, 32, 30, 0.68);
    font-size: 0.82rem;
    transform: rotate(1.5deg);
  }

  .craft-values ol {
    display: grid;
    justify-items: start;
    gap: 0.15rem;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .craft-values li {
    position: relative;
    display: inline-grid;
    grid-template-columns: 3rem minmax(0, auto);
    align-items: center;
    gap: 0.15rem;
    width: fit-content;
    max-width: 100%;
    padding: 0;
  }

  .craft-values li:nth-child(2) {
    margin-left: 0;
    transform: rotate(0.45deg);
  }

  .craft-values li:nth-child(3) {
    margin-left: 0;
    transform: rotate(-0.55deg);
  }

  .craft-values__check {
    position: relative;
    display: block;
    width: 1.45rem;
    height: 1.45rem;
    transform: rotate(-2.5deg);
    transition: transform 80ms ease;
  }

  .craft-values li:nth-child(2) .craft-values__check {
    transform: rotate(2deg);
  }

  .craft-values li:nth-child(3) .craft-values__check {
    transform: rotate(-1deg);
  }

  .craft-values__check-svg {
    display: block;
    width: 100%;
    height: 100%;
    overflow: visible;
  }

  .craft-values__outline,
  .craft-values__tick {
    fill: transparent;
    stroke: currentColor;
    stroke-linecap: round;
    stroke-linejoin: round;
    vector-effect: non-scaling-stroke;
  }

  .craft-values__outline {
    stroke-width: 1.65;
    transition: fill 80ms ease, stroke-width 80ms ease;
  }

  .craft-values__tick {
    stroke-width: 2.15;
    stroke-dasharray: 100;
    stroke-dashoffset: 100;
    transition: stroke-dashoffset 115ms cubic-bezier(0.22, 0.75, 0.3, 1);
  }

  .craft-values__input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .craft-values__check-control {
    display: grid;
    width: 3rem;
    min-height: 3rem;
    align-items: center;
    justify-content: center;
    border-radius: 48% 42% 53% 45%;
    cursor: pointer;
    transition: background-color 80ms ease;
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__check {
    animation: checkbox-settle 135ms ease-out;
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__outline {
    fill: rgba(134, 69, 56, 0.045);
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__tick {
    stroke-dashoffset: 0;
    transition-delay: 18ms;
  }

  .craft-values__input:focus-visible + .craft-values__check-control {
    outline: var(--focus-width) solid var(--color-focus);
    outline-offset: var(--focus-offset);
  }

  .craft-values li p {
    position: relative;
    width: fit-content;
    max-width: 36ch;
    font-size: clamp(1.05rem, 1.8vw, 1.35rem);
    line-height: 1.3;
    transition: opacity 90ms ease;
  }

  .craft-values__strike {
    position: absolute;
    z-index: 2;
    top: 53%;
    left: -0.12em;
    width: calc(100% + 0.24em);
    height: 0.09em;
    border-radius: 999px 35% 999px 45%;
    background: linear-gradient(90deg, currentColor, rgba(32, 32, 30, 0.72) 46%, currentColor);
    opacity: 0;
    pointer-events: none;
    transform: rotate(-0.7deg) scaleX(0);
    transform-origin: left center;
    transition: opacity 45ms linear, transform 120ms cubic-bezier(0.22, 0.75, 0.3, 1);
  }

  .craft-values__input:checked ~ p .craft-values__strike {
    opacity: 0.66;
    transform: rotate(-0.7deg) scaleX(1);
    transition-delay: 65ms;
  }

  .craft-values__input:checked ~ p {
    opacity: 0.82;
  }

  .word-cycle {
    min-height: 2.75rem;
    padding: 0 0.08em;
    border: 0;
    border-bottom: 0.14rem solid currentColor;
    background: transparent;
    color: #864538;
    font: inherit;
    cursor: default;
  }

  .word-cycle__option + .word-cycle__option::before {
    color: var(--color-ink);
    content: ' / ';
  }

  .craft-values[data-enhanced] .word-cycle {
    cursor: pointer;
  }

  .craft-values[data-enhanced] .word-cycle__option:not([data-active]) {
    display: none;
  }

  .craft-values[data-enhanced] .word-cycle__option + .word-cycle__option::before {
    content: none;
  }

  @media (hover: hover) and (pointer: fine) {
    .craft-values__check-control:hover {
      background: rgba(134, 69, 56, 0.045);
    }

    .craft-values__input:not(:checked) + .craft-values__check-control:hover .craft-values__check {
      scale: 1.035;
    }

    .craft-values__input:not(:checked) + .craft-values__check-control:hover .craft-values__outline {
      fill: rgba(134, 69, 56, 0.025);
      stroke-width: 1.85;
    }
  }

  .craft-values__check-control:active .craft-values__check {
    scale: 0.96;
  }

  @keyframes checkbox-settle {
    0% {
      scale: 1;
      translate: 0 0;
    }
    48% {
      scale: 1.055 0.95;
      translate: 0 0.05rem;
    }
    78% {
      scale: 0.99 1.015;
      translate: 0 -0.025rem;
    }
    100% {
      scale: 1;
      translate: 0 0;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .craft-values__input:checked + .craft-values__check-control .craft-values__check {
      animation-duration: 0.01ms;
      animation-delay: 0ms;
    }

    .craft-values__check,
    .craft-values__outline,
    .craft-values__tick,
    .craft-values li p,
    .craft-values__strike {
      transition-duration: 0.01ms;
      transition-delay: 0ms;
    }
  }

  @media (max-width: 36rem) {
    .craft-values__heading {
      display: flex;
    }

    .craft-values li,
    .craft-values li:nth-child(2),
    .craft-values li:nth-child(3) {
      grid-template-columns: 3rem minmax(0, auto);
      gap: 0.1rem;
    }

    .craft-values li:nth-child(2),
    .craft-values li:nth-child(3) {
      margin-left: 0;
    }

    .craft-values__strike {
      display: none;
    }

    .craft-values__copy,
    .word-cycle {
      text-decoration-line: line-through;
      text-decoration-color: transparent;
      text-decoration-thickness: 0.075em;
      text-decoration-skip-ink: none;
      transition: opacity 140ms ease, text-decoration-color 150ms ease;
    }

    .craft-values__input:checked ~ p .craft-values__copy,
    .craft-values__input:checked ~ p .word-cycle {
      text-decoration-color: rgba(32, 32, 30, 0.62);
      transition-delay: 110ms;
    }
  }

  @media (prefers-reduced-motion: reduce) and (max-width: 36rem) {
    .craft-values__copy,
    .word-cycle {
      transition-duration: 0.01ms;
      transition-delay: 0ms;
    }
  }
</style>
