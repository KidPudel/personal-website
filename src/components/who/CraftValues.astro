---
import { connectLinks } from '../../config/site';

const values = [
  {
    words: ['experience', 'behaviour', 'capability'],
    before: 'Fulfil a real wish for ',
    after: '.',
  },
  {
    words: ['impactful', 'empowering'],
    before: 'Create an ',
    after: ' interaction experience.',
  },
  {
    words: ['clear', 'honest'],
    before: 'Be ',
    after: ' with users or players.',
  },
] as const;
---

<craft-values class="craft-values" aria-label="What matters to me in the things I make">
  <div class="craft-values__heading">
    <p>three notes for the things I make</p>
    <span aria-hidden="true">tap a changing word</span>
  </div>

  <ol role="list">
    {values.map((value, index) => (
      <li>
        <input
          class="craft-values__input"
          type="checkbox"
          id={`craft-value-${index + 1}`}
          aria-label={`Mark value ${index + 1} as checked`}
        />
        <label class="craft-values__check-control" for={`craft-value-${index + 1}`}>
          <span class="craft-values__check" aria-hidden="true"></span>
        </label>
        <p>
          <span class="craft-values__copy">
            {value.before}
            <button
              type="button"
              class="word-cycle"
              data-word-cycle
              data-value-number={index + 1}
              aria-label={`${value.words.join(', ')}. Word choices.`}
              disabled
            >
              {value.words.map((word, wordIndex) => (
                <span
                  class="word-cycle__option"
                  data-word-option
                  data-active={wordIndex === 0 ? '' : undefined}
                >
                  {word}
                </span>
              ))}
            </button>{value.after}
          </span>
          <span class="craft-values__strike" aria-hidden="true"></span>
        </p>
      </li>
    ))}
  </ol>

  <div class="craft-values__completion" data-craft-completion aria-live="polite" hidden>
    <p>I'd love to chat with you.</p>
    <div class="craft-values__connect-links" aria-label="Connect options">
      {connectLinks.map((link) => <a href={link.href}>{link.label}</a>)}
    </div>
  </div>
</craft-values>

<script>
  class CraftValues extends HTMLElement {
    connectedCallback() {
      if (this.dataset.enhanced) return;

      const controls = Array.from(this.querySelectorAll<HTMLButtonElement>('[data-word-cycle]'));
      const checkboxes = Array.from(this.querySelectorAll<HTMLInputElement>('.craft-values__input'));
      const completion = this.querySelector<HTMLElement>('[data-craft-completion]');
      if (!controls.length || !checkboxes.length || !completion) return;

      this.dataset.enhanced = 'true';

      controls.forEach((button) => {
        const options = Array.from(button.querySelectorAll<HTMLElement>('[data-word-option]'));
        let activeIndex = 0;

        const update = () => {
          options.forEach((option, index) => {
            const isActive = index === activeIndex;
            option.toggleAttribute('data-active', isActive);
            option.setAttribute('aria-hidden', String(!isActive));
          });

          const currentWord = options[activeIndex]?.textContent?.trim() ?? '';
          button.setAttribute('aria-label', `${currentWord}. Change this word.`);
        };

        button.disabled = false;
        button.addEventListener('click', () => {
          activeIndex = (activeIndex + 1) % options.length;
          update();
        });
        update();
      });

      let completionScrollTimer: number | undefined;

      const updateCompletion = () => {
        const complete = checkboxes.every((checkbox) => checkbox.checked);
        const wasComplete = this.hasAttribute('data-complete');
        completion.hidden = !complete;
        this.toggleAttribute('data-complete', complete);

        if (completionScrollTimer) {
          window.clearTimeout(completionScrollTimer);
          completionScrollTimer = undefined;
        }

        if (complete && !wasComplete) {
          const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
          completionScrollTimer = window.setTimeout(() => {
            if (!this.hasAttribute('data-complete')) return;

            completion.scrollIntoView({
              behavior: reduceMotion ? 'auto' : 'smooth',
              block: 'nearest',
            });
          }, reduceMotion ? 0 : 260);
        }
      };

      checkboxes.forEach((checkbox) => checkbox.addEventListener('change', updateCompletion));
      updateCompletion();
    }
  }

  if (!customElements.get('craft-values')) {
    customElements.define('craft-values', CraftValues);
  }
</script>

<style>
  .craft-values {
    display: block;
    max-width: 54rem;
    margin: clamp(4.5rem, 10vw, 8rem) auto 1rem;
  }

  .craft-values__heading {
    display: flex;
    align-items: end;
    justify-content: space-between;
    gap: 1rem;
    margin-bottom: 1.7rem;
  }

  .craft-values__heading p {
    font-size: clamp(1.15rem, 2vw, 1.45rem);
  }

  .craft-values__heading span {
    color: rgba(32, 32, 30, 0.68);
    font-size: 0.92rem;
    transform: rotate(-2deg);
  }

  .craft-values ol {
    display: grid;
    gap: 0;
    padding: 0;
    margin: 0;
    list-style: none;
  }

  .craft-values li {
    position: relative;
    display: grid;
    grid-template-columns: 2.7rem minmax(0, 1fr);
    align-items: start;
    gap: 0.9rem;
    padding: 1.4rem 0.3rem 1.55rem;
  }

  .craft-values li::before,
  .craft-values li:last-child::after {
    position: absolute;
    left: var(--rule-left, 0.2rem);
    width: var(--rule-width, calc(100% - 0.5rem));
    height: 0.08rem;
    background: rgba(32, 32, 30, 0.28);
    content: '';
    transform: rotate(var(--rule-tilt, -0.15deg));
    transform-origin: left center;
  }

  .craft-values li::before {
    top: 0;
  }

  .craft-values li:last-child::after {
    bottom: 0;
    --rule-left: 0.65rem;
    --rule-width: calc(100% - 1rem);
    --rule-tilt: 0.25deg;
  }

  .craft-values li:nth-child(2) {
    padding-left: clamp(0rem, 3vw, 2.2rem);
    --rule-left: 1.2rem;
    --rule-width: calc(100% - 1.45rem);
    --rule-tilt: 0.35deg;
  }

  .craft-values li:nth-child(3) {
    padding-left: clamp(0rem, 1.5vw, 1rem);
    --rule-left: 0.45rem;
    --rule-width: calc(100% - 1.3rem);
    --rule-tilt: -0.4deg;
  }

  .craft-values__check {
    position: relative;
    display: block;
    width: 2rem;
    height: 1.8rem;
    border-color: currentColor;
    border-style: solid;
    border-width: 0.12rem 0.18rem 0.16rem 0.13rem;
    border-radius: 14% 7% 18% 9%;
    box-shadow: inset 0.04rem -0.03rem 0 rgba(32, 32, 30, 0.22);
    transform: rotate(-3deg) skewX(-1deg);
    transition: background-color 120ms ease, box-shadow 120ms ease;
  }

  .craft-values li:nth-child(2) .craft-values__check {
    border-width: 0.17rem 0.12rem 0.13rem 0.18rem;
    border-radius: 8% 17% 6% 15%;
    transform: rotate(2.5deg) skewY(1deg);
  }

  .craft-values li:nth-child(3) .craft-values__check {
    border-width: 0.13rem 0.16rem 0.19rem 0.11rem;
    border-radius: 17% 9% 13% 5%;
    transform: rotate(-1.5deg) skewX(1.5deg);
  }

  .craft-values__check::before,
  .craft-values__check::after {
    position: absolute;
    height: 0.2rem;
    border-radius: 999px 35% 999px 45%;
    background: currentColor;
    content: '';
    opacity: 0;
    transform-origin: left center;
  }

  .craft-values__check::before {
    top: 0.88rem;
    left: 0.15rem;
    width: 0.8rem;
    transform: rotate(42deg) scaleX(0);
    transition: opacity 50ms linear, transform 110ms ease-in;
  }

  .craft-values__check::after {
    top: 1.38rem;
    left: 0.72rem;
    width: 1.65rem;
    transform: rotate(-49deg) scaleX(0);
    transition: opacity 60ms linear, transform 160ms ease-out;
  }

  .craft-values__input {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border: 0;
  }

  .craft-values__check-control {
    display: grid;
    width: 2.75rem;
    min-height: 2.75rem;
    align-items: center;
    justify-content: start;
    cursor: pointer;
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__check {
    background: rgba(134, 69, 56, 0.055);
    box-shadow: inset 0.04rem -0.03rem 0 rgba(32, 32, 30, 0.18), 0 0.12rem 0 rgba(32, 32, 30, 0.08);
    animation: checkbox-settle 210ms ease-out;
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__check::before {
    opacity: 1;
    transform: rotate(42deg) scaleX(1);
    transition-delay: 35ms;
  }

  .craft-values__input:checked + .craft-values__check-control .craft-values__check::after {
    opacity: 1;
    transform: rotate(-49deg) scaleX(1);
    transition-delay: 110ms;
  }

  .craft-values__input:focus-visible + .craft-values__check-control {
    outline: var(--focus-width) solid var(--color-focus);
    outline-offset: var(--focus-offset);
  }

  .craft-values li p {
    position: relative;
    width: fit-content;
    max-width: 35ch;
    font-size: clamp(1.35rem, 3vw, 2.25rem);
    line-height: 1.35;
    transition: opacity 140ms ease;
  }

  .craft-values__strike {
    position: absolute;
    z-index: 2;
    top: 53%;
    left: -0.12em;
    width: calc(100% + 0.24em);
    height: 0.09em;
    border-radius: 999px 35% 999px 45%;
    background: linear-gradient(90deg, currentColor, rgba(32, 32, 30, 0.72) 46%, currentColor);
    opacity: 0;
    pointer-events: none;
    transform: rotate(-0.7deg) scaleX(0);
    transform-origin: left center;
    transition: opacity 80ms linear, transform 180ms cubic-bezier(0.22, 0.75, 0.3, 1);
  }

  .craft-values__input:checked ~ p .craft-values__strike {
    opacity: 0.66;
    transform: rotate(-0.7deg) scaleX(1);
    transition-delay: 145ms;
  }

  .craft-values__input:checked ~ p {
    opacity: 0.82;
  }

  .word-cycle {
    min-height: 2.75rem;
    padding: 0 0.08em;
    border: 0;
    border-bottom: 0.14rem solid currentColor;
    background: transparent;
    color: #864538;
    font: inherit;
    cursor: default;
  }

  .word-cycle__option + .word-cycle__option::before {
    color: var(--color-ink);
    content: ' / ';
  }

  .craft-values[data-enhanced] .word-cycle {
    cursor: pointer;
  }

  .craft-values[data-enhanced] .word-cycle__option:not([data-active]) {
    display: none;
  }

  .craft-values[data-enhanced] .word-cycle__option + .word-cycle__option::before {
    content: none;
  }

  .craft-values__completion {
    width: fit-content;
    max-width: 100%;
    margin: 2.2rem 0.5rem 0 auto;
    padding: 1rem 1.2rem 0.9rem;
    border: 0.1rem solid rgba(32, 32, 30, 0.46);
    border-width: 0.12rem 0.16rem 0.1rem 0.13rem;
    border-radius: 7% 3% 8% 4%;
    scroll-margin-block: 1.5rem;
    transform: rotate(-0.7deg);
  }

  .craft-values__completion[hidden] {
    display: none;
  }

  .craft-values[data-complete] .craft-values__completion {
    animation: completion-arrives 320ms ease-out both;
  }

  .craft-values__completion > p {
    max-width: none;
    font-size: clamp(1.25rem, 2.4vw, 1.7rem);
  }

  .craft-values__connect-links {
    display: flex;
    max-width: 34rem;
    flex-wrap: wrap;
    gap: 0.15rem 1.1rem;
    margin-top: 0.45rem;
  }

  .craft-values__connect-links a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    color: #864538;
    font-size: 1rem;
    text-decoration-thickness: 0.1rem;
    text-underline-offset: 0.24em;
  }

  @media (hover: hover) and (pointer: fine) {
    .craft-values__input:not(:checked) + .craft-values__check-control:hover .craft-values__check {
      background: rgba(134, 69, 56, 0.035);
      box-shadow: inset 0.04rem -0.03rem 0 rgba(32, 32, 30, 0.18), 0 0.12rem 0 rgba(32, 32, 30, 0.07);
    }
  }

  .craft-values__check-control:active .craft-values__check {
    scale: 0.96;
  }

  @keyframes checkbox-settle {
    0% {
      scale: 1;
      translate: 0 0;
    }
    48% {
      scale: 1.055 0.95;
      translate: 0 0.05rem;
    }
    78% {
      scale: 0.99 1.015;
      translate: 0 -0.025rem;
    }
    100% {
      scale: 1;
      translate: 0 0;
    }
  }

  @keyframes completion-arrives {
    from {
      opacity: 0;
      transform: translateY(0.7rem) rotate(-1.8deg);
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(-0.7deg);
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .craft-values__input:checked + .craft-values__check-control .craft-values__check,
    .craft-values[data-complete] .craft-values__completion {
      animation-duration: 0.01ms;
      animation-delay: 0ms;
    }

    .craft-values__check,
    .craft-values__check::before,
    .craft-values__check::after,
    .craft-values li p,
    .craft-values__strike {
      transition-duration: 0.01ms;
      transition-delay: 0ms;
    }
  }

  @media (max-width: 36rem) {
    .craft-values__heading {
      display: grid;
    }

    .craft-values li,
    .craft-values li:nth-child(2),
    .craft-values li:nth-child(3) {
      grid-template-columns: 2.25rem minmax(0, 1fr);
      gap: 0.65rem;
      padding-inline: 0;
    }

    .craft-values__check {
      width: 1.7rem;
      height: 1.55rem;
    }

    .craft-values__strike {
      display: none;
    }

    .craft-values__copy,
    .word-cycle {
      text-decoration-line: line-through;
      text-decoration-color: transparent;
      text-decoration-thickness: 0.075em;
      text-decoration-skip-ink: none;
      transition: opacity 140ms ease, text-decoration-color 150ms ease;
    }

    .craft-values__input:checked ~ p .craft-values__copy,
    .craft-values__input:checked ~ p .word-cycle {
      text-decoration-color: rgba(32, 32, 30, 0.62);
      transition-delay: 110ms;
    }
  }

  @media (prefers-reduced-motion: reduce) and (max-width: 36rem) {
    .craft-values__copy,
    .word-cycle {
      transition-duration: 0.01ms;
      transition-delay: 0ms;
    }
  }
</style>
