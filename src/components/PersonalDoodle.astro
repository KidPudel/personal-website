---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';

interface Props {
  image: ImageMetadata;
  label: string;
  caption?: string;
  class?: string;
  artScale?: number;
}

const {
  image,
  label,
  caption,
  class: className,
  artScale = 1,
} = Astro.props;
---

<figure
  class:list={['personal-doodle', className]}
  style={`--doodle-art-scale: ${artScale}`}
>
  <span class="personal-doodle-stage" role="img" aria-label={label}>
    <Image
      class="personal-doodle-frame"
      src={image}
      alt=""
      width={384}
      format="webp"
      loading="lazy"
    />
  </span>
  {caption && <figcaption>{caption}</figcaption>}
</figure>
