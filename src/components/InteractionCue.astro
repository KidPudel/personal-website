---
interface Props {
  kind?: 'click' | 'switch';
}

const { kind = 'click' } = Astro.props;
---

<span class:list={['interaction-cue', `interaction-cue-${kind}`]} aria-hidden="true">
  {
    kind === 'switch' ? (
      <svg viewBox="0 0 24 24">
        <path d="M6 8a7 7 0 0 1 11-1l2 2m0 0V5m0 4h-4M18 16a7 7 0 0 1-11 1l-2-2m0 0v4m0-4h4" />
      </svg>
    ) : (
      <svg viewBox="0 0 24 24">
        <path d="m6 4 11 9-5 1 3 5-2 1-3-5-4 4V4Z" />
      </svg>
    )
  }
</span>
