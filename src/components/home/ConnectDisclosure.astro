---
import connectIcon from '../../assets/art/icons/Doodles_connect.png';
import { connectLinks } from '../../config/site';
import NavigationDrawing from './NavigationDrawing.astro';
---

<connect-disclosure id="connect">
  <NavigationDrawing
    art={connectIcon}
    artScale={2.2}
    label="Connect"
    labelPlacement="lower-right"
    class="connect-choice"
    connectToggle
    ariaControls="connect-links"
    ariaExpanded={true}
    tilt="-2deg"
  />

  <div id="connect-links" class="connect-links">
    {connectLinks.map((link) => <a href={link.href}>{link.label}</a>)}
  </div>
</connect-disclosure>

<script>
  class ConnectDisclosureElement extends HTMLElement {
    private button?: HTMLButtonElement;
    private panel?: HTMLElement;

    private setExpanded = (expanded: boolean, announce = false) => {
      if (!this.button || !this.panel) return;

      this.button.setAttribute('aria-expanded', String(expanded));
      this.panel.hidden = !expanded;
      this.toggleAttribute('data-open', expanded);

      if (expanded && announce) {
        window.dispatchEvent(new CustomEvent('home-disclosure-open', { detail: { id: 'connect' } }));
      }
    };

    private clearConnectHash = () => {
      if (window.location.hash !== '#connect') return;
      window.history.replaceState(null, '', `${window.location.pathname}${window.location.search}`);
    };

    private syncFromHash = () => this.setExpanded(window.location.hash === '#connect');

    private handleToggle = () => {
      if (!this.button) return;

      const expanded = this.button.getAttribute('aria-expanded') !== 'true';
      this.setExpanded(expanded, expanded);

      const nextURL = expanded
        ? `${window.location.pathname}${window.location.search}#connect`
        : `${window.location.pathname}${window.location.search}`;
      window.history.replaceState(null, '', nextURL);
    };

    private handleOutsidePointer = (event: PointerEvent) => {
      if (!this.hasAttribute('data-open') || this.contains(event.target as Node)) return;
      this.setExpanded(false);
      this.clearConnectHash();
    };

    private handleEscape = (event: KeyboardEvent) => {
      if (event.key !== 'Escape' || !this.hasAttribute('data-open')) return;
      this.setExpanded(false);
      this.clearConnectHash();
      this.button?.focus();
    };

    private handleOtherDisclosure = (event: Event) => {
      const disclosureEvent = event as CustomEvent<{ id?: string }>;
      if (disclosureEvent.detail?.id === 'connect') return;
      this.setExpanded(false);
      this.clearConnectHash();
    };

    connectedCallback() {
      if (this.hasAttribute('data-enhanced')) return;

      this.button = this.querySelector<HTMLButtonElement>('[data-connect-toggle]') ?? undefined;
      this.panel = this.querySelector<HTMLElement>('#connect-links') ?? undefined;
      if (!this.button || !this.panel) return;

      this.setAttribute('data-enhanced', '');
      this.syncFromHash();

      this.button.addEventListener('click', this.handleToggle);
      document.addEventListener('pointerdown', this.handleOutsidePointer);
      document.addEventListener('keydown', this.handleEscape);
      window.addEventListener('hashchange', this.syncFromHash);
      window.addEventListener('home-disclosure-open', this.handleOtherDisclosure);
    }

    disconnectedCallback() {
      this.button?.removeEventListener('click', this.handleToggle);
      document.removeEventListener('pointerdown', this.handleOutsidePointer);
      document.removeEventListener('keydown', this.handleEscape);
      window.removeEventListener('hashchange', this.syncFromHash);
      window.removeEventListener('home-disclosure-open', this.handleOtherDisclosure);
    }
  }

  if (!customElements.get('connect-disclosure')) {
    customElements.define('connect-disclosure', ConnectDisclosureElement);
  }
</script>

<style>
  connect-disclosure {
    position: relative;
    z-index: 5;
    display: block;
    width: max-content;
    max-width: 100%;
  }

  .connect-links {
    position: absolute;
    z-index: 6;
    right: 3rem;
    bottom: calc(100% + 1rem);
    display: grid;
    width: max-content;
    justify-items: start;
    gap: 0.15rem;
  }

  .connect-links::after {
    position: absolute;
    top: calc(100% + 0.65rem);
    left: 1rem;
    width: 2rem;
    height: 3.5rem;
    border-left: 0.14rem solid color-mix(in srgb, var(--color-field-ink) 58%, transparent);
    border-radius: 50%;
    content: '';
    transform: rotate(-11deg);
    transform-origin: top;
  }

  .connect-links[hidden] {
    display: none;
  }

  .connect-links a {
    position: relative;
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    color: var(--color-field-ink);
    font-size: clamp(1rem, 1.55vw, 1.15rem);
    text-underline-offset: 0.22em;
  }

  connect-disclosure:not([data-enhanced]) .connect-links {
    display: grid;
  }

  @media (max-width: 40rem) {
    connect-disclosure {
      display: flex;
      width: 100%;
      flex-direction: column-reverse;
      align-items: center;
    }

    connect-disclosure[data-open],
    connect-disclosure:not([data-enhanced]) {
      grid-column: 1 / -1;
    }

    .connect-links,
    connect-disclosure:not([data-enhanced]) .connect-links {
      position: static;
      display: flex;
      width: min(100%, 24rem);
      flex-wrap: wrap;
      justify-content: center;
      gap: 0.15rem 1.1rem;
      margin-bottom: 1rem;
    }

    .connect-links::after {
      display: none;
    }

    .connect-links a {
      font-size: 1rem;
    }
  }
</style>
