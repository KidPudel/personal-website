---
import blogIcon from '../../assets/art/icons/Doodles_blog.png';
import whoIAmIcon from '../../assets/art/icons/Doodles_whoiam.png';
import { sitePath } from '../../config/site';
import ConnectDisclosure from './ConnectDisclosure.astro';
import NavigationDrawing from './NavigationDrawing.astro';
import WorkDisclosure from './WorkDisclosure.astro';
---

<section class="home-map" aria-labelledby="home-title">
  <h1 id="home-title" class="sr-only">Igor Kupchinenko</h1>

  <nav class="home-map__choices" aria-label="Explore Igor's website">
    <NavigationDrawing
      art={whoIAmIcon}
      artScale={1.7}
      class="choice-who"
      label="Who I am"
      labelPlacement="upper-right"
      href={sitePath('/who-i-am/')}
      tilt="-2deg"
    />
    <WorkDisclosure />
    <ConnectDisclosure />
    <NavigationDrawing
      art={blogIcon}
      artScale={2}
      class="choice-blog"
      label="Blog"
      labelPlacement="below-right"
      href={sitePath('/blog/')}
      tilt="-1deg"
    />
  </nav>
</section>

<style>
  .home-map {
    position: relative;
    isolation: isolate;
    display: grid;
    min-height: calc(100vh - (2 * var(--field-gutter)));
    overflow: clip;
    place-items: center;
    pointer-events: none;
  }

  .home-map__choices {
    position: relative;
    z-index: 2;
    display: grid;
    width: min(100%, 50rem);
    min-height: min(66vh, 36rem);
    grid-template-columns: repeat(3, minmax(0, 1fr));
    grid-template-rows: repeat(3, minmax(0, 1fr));
    align-items: center;
    gap: 1rem clamp(1rem, 4vw, 3rem);
    padding: 1rem;
    pointer-events: auto;
  }

  .home-map__choices :global(.choice-who) {
    grid-column: 2;
    grid-row: 1;
    align-self: end;
    justify-self: center;
  }

  .home-map__choices :global(work-disclosure) {
    grid-column: 3;
    grid-row: 2;
    justify-self: start;
  }

  .home-map__choices :global(connect-disclosure) {
    grid-column: 1;
    grid-row: 2;
    justify-self: end;
  }

  .home-map__choices :global(.choice-blog) {
    grid-column: 2;
    grid-row: 3;
    align-self: start;
    justify-self: center;
  }

  @media (max-width: 40rem) {
    .home-map {
      min-height: calc(100vh - 1.75rem);
      align-items: center;
      overflow: clip;
    }

    .home-map__choices {
      width: 100%;
      min-height: auto;
      grid-template-columns: repeat(2, minmax(0, 1fr));
      grid-template-rows: none;
      gap: 3.5rem 1rem;
      padding: 2.5rem 0.5rem;
    }

    .home-map__choices :global(.choice-who),
    .home-map__choices :global(work-disclosure),
    .home-map__choices :global(connect-disclosure),
    .home-map__choices :global(.choice-blog) {
      grid-column: auto;
      grid-row: auto;
      align-self: auto;
      justify-self: center;
      margin: 0;
    }

    .home-map__choices :global(connect-disclosure[data-open]),
    .home-map__choices :global(connect-disclosure:not([data-enhanced])),
    .home-map__choices :global(work-disclosure[data-open]),
    .home-map__choices :global(work-disclosure:not([data-enhanced])) {
      grid-column: 1 / -1;
      grid-row: auto;
      justify-self: stretch;
    }

  }
</style>
