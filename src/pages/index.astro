---
import { Image } from 'astro:assets';

import avatar from '../assets/art/avatar.png';
import avatarIrl from '../assets/art/avatar_irl.png';
import campfireFrame3 from '../assets/art/doodles/campfire/frame-3.png';
import cdDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-1.png';
import thoughtsDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-2.png';
import computerDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-3.png';
import birdDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-4.png';
import burgerDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-5.png';
import cameraDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-6.png';
import fishDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-7.png';
import fishboneDoodle from '../assets/art/doodles/campfire/Doodles_For_Website_-8.png';
import InteractionCue from '../components/InteractionCue.astro';
import PersonalDoodle from '../components/PersonalDoodle.astro';
import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import { paperTransition } from '../config/transitions';
import BaseLayout from '../layouts/BaseLayout.astro';

const base = import.meta.env.BASE_URL;

const values = [
  {
    number: '01',
    id: 'meaning',
    title: 'It is meaningful.',
    note: 'It is clear why we are here.',
  },
  {
    number: '02',
    id: 'joy',
    title: 'It makes the world more joyful.',
    note: "It fulfills someone's wish for a new capability.",
  },
  {
    number: '03',
    id: 'experience',
    title: 'The artifact becomes real.',
    note: 'It becomes a tool, a game, or another complete thing that can stand on its own.',
  },
] as const;

const notebookDoodles = [
  { image: cdDoodle, label: 'A hand-drawn CD case', className: 'values-sketch-cd', artScale: 1.12 },
  { image: thoughtsDoodle, label: 'A hand-drawn tangle of thoughts', className: 'values-sketch-thoughts', artScale: 1.08 },
  { image: computerDoodle, label: 'A cute hand-drawn computer', className: 'values-sketch-computer', artScale: 1.1 },
  { image: birdDoodle, label: 'A small hand-drawn bird', className: 'values-sketch-bird', artScale: 1.08 },
  { image: burgerDoodle, label: 'A hand-drawn burger', className: 'values-sketch-burger', artScale: 1.12 },
  { image: cameraDoodle, label: 'A hand-drawn camera', className: 'values-sketch-camera', artScale: 1.08 },
  { image: fishDoodle, label: 'A hand-drawn fish with bubbles', className: 'values-sketch-fish', artScale: 1.08 },
  { image: fishboneDoodle, label: 'A hand-drawn fishbone', className: 'values-sketch-fishbone', artScale: 1.12 },
] as const;
---

<BaseLayout page="home">
  <div class="site-frame">
    <SiteHeader active="home" />

    <main id="main-content" class="notebook notebook-page home-page" transition:name="notebook-page" transition:animate={paperTransition}>
      <section class="home-intro" aria-labelledby="home-title">
        <div class="home-opening">
          <p class="eyebrow"><span aria-hidden="true">✦</span> hello, I am Igor</p>
          <h1 id="home-title">A quick glimpse into <span>Igor's personal notebook.</span></h1>
          <p class="home-lede">I build production software, make games, and write. This page is about the values underneath those things.</p>
          <a class="scroll-note" href="#values">keep scrolling <span aria-hidden="true">↓</span></a>
        </div>

        <figure class="home-portrait" data-portrait-switcher>
          <div class="portrait-stack" data-portrait-stack>
            <div class="portrait-panel is-active" data-portrait-panel data-caption="drawn by me" aria-hidden="false">
              <span class="portrait-tape" aria-hidden="true"></span>
              <Image src={avatar} alt="A black-and-white hand-drawn avatar with large dark eyes and curly hair" width={520} height={520} loading="eager" format="webp" />
              <span class="portrait-card-label">drawn by me</span>
            </div>
            <div class="portrait-panel" data-portrait-panel data-caption="real me" aria-hidden="true">
              <span class="portrait-tape" aria-hidden="true"></span>
              <Image src={avatarIrl} alt="Igor smiling in a cap and orange life jacket while sitting in a boat" width={520} loading="eager" format="webp" />
              <span class="portrait-card-label">real me</span>
            </div>
          </div>
          <figcaption>
            <span class="sr-only" data-portrait-caption>drawn by me</span>
            <button type="button" data-portrait-next hidden>
              <span>swap polaroid</span>
              <InteractionCue kind="switch" />
            </button>
          </figcaption>
        </figure>
      </section>

      <section id="values" class="values-section" aria-labelledby="values-title">
        <div class="values-doodle-layer" aria-hidden="true">
          <PersonalDoodle
            class="values-campfire"
            image={campfireFrame3}
            label="A strong campfire drawn by Igor"
            artScale={1}
          />

          {notebookDoodles.map((doodle) => (
            <PersonalDoodle
              class={`values-sketch ${doodle.className}`}
              image={doodle.image}
              label={doodle.label}
              artScale={doodle.artScale}
            />
          ))}
        </div>

        <header class="values-heading">
          <div>
            <p class="eyebrow">three notes for the things I make</p>
            <h2 id="values-title">What matters to <em>me</em> in my work.</h2>
            <p>Three outcomes I want from software, games, tools, and other artifacts.</p>
          </div>
        </header>

        <div class="values-workspace">
          <div class="values-checklist-column">
            <div class="values-list">
              {values.map((value) => (
                <article class={`value-entry value-${value.id}`} data-value-entry>
                  <label class="value-toggle">
                    <input class="value-input" type="checkbox" data-value-input />
                    <span class="value-checkbox" aria-hidden="true">
                      <svg viewBox="0 0 64 64">
                        <path class="checkbox-box" d="M10 12c12-2 29-2 43 1 1 12 1 27-2 40-12 1-27 1-40-2-1-13-1-27-1-39Z"/>
                        <path class="checkbox-check" d="m16 33 10 10 23-25"/>
                      </svg>
                    </span>
                    <span class="value-copy">
                      <span class="value-number">{value.number}</span>
                      <strong>{value.title}</strong>
                      <span class="value-note"><span aria-hidden="true">↳ note:</span> {value.note}</span>
                    </span>
                  </label>
                </article>
              ))}
            </div>

            <aside class="values-complete-note" data-values-complete aria-live="polite" hidden>
              <p><span aria-hidden="true">✦</span> Hey, I've been looking for you.</p>
              <a href={`${base}connect/`}>
                <span>Let's chat</span>
                <InteractionCue />
              </a>
            </aside>
          </div>
        </div>
      </section>

      <nav class="next-pages" aria-label="Continue through the notebook">
        <p>Those outcomes turn into different kinds of evidence.</p>
        <a href={`${base}work/`}><span>professional systems</span><strong>Work</strong></a>
        <a href={`${base}games/`}><span>playable systems</span><strong>Games</strong></a>
        <a href={`${base}blog/`}><span>thoughts in progress</span><strong>Blog</strong></a>
      </nav>
    </main>

    <SiteFooter />
  </div>

  <script>
    const initializeHome = () => {
      const entries = document.querySelectorAll<HTMLElement>('[data-value-entry]:not([data-bound])');
      const valuesList = document.querySelector<HTMLElement>('.values-list');
      const completionNote = document.querySelector<HTMLElement>('[data-values-complete]');
      const prefersReducedMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

      valuesList?.classList.add('is-enhanced');

      const reveal = (entry: HTMLElement) => entry.classList.add('is-visible');
      if ('IntersectionObserver' in window && !prefersReducedMotion) {
        const observer = new IntersectionObserver((items) => {
          items.forEach((item) => {
            if (item.isIntersecting) {
              reveal(item.target as HTMLElement);
              observer.unobserve(item.target);
            }
          });
        }, { threshold: 0.28 });
        entries.forEach((entry) => observer.observe(entry));
      } else {
        entries.forEach(reveal);
      }

      if (valuesList && completionNote && !valuesList.dataset.completionBound) {
        valuesList.dataset.completionBound = 'true';
        const inputs = Array.from(valuesList.querySelectorAll<HTMLInputElement>('[data-value-input]'));
        const updateCompletion = () => {
          const isComplete = inputs.length > 0 && inputs.every((input) => input.checked);
          completionNote.hidden = !isComplete;
        };

        inputs.forEach((input) => input.addEventListener('change', updateCompletion));
        updateCompletion();
      }

      const portrait = document.querySelector<HTMLElement>('[data-portrait-switcher]:not([data-bound])');
      if (portrait) {
        portrait.dataset.bound = 'true';
        const panels = Array.from(portrait.querySelectorAll<HTMLElement>('[data-portrait-panel]'));
        const stack = portrait.querySelector<HTMLElement>('[data-portrait-stack]');
        const button = portrait.querySelector<HTMLButtonElement>('[data-portrait-next]');
        const caption = portrait.querySelector<HTMLElement>('[data-portrait-caption]');
        let active = Math.max(0, panels.findIndex((panel) => panel.classList.contains('is-active')));
        if (button) button.hidden = false;
        button?.addEventListener('click', () => {
          if (button.disabled) return;

          const previous = panels[active];
          active = (active + 1) % panels.length;
          const next = panels[active];
          if (!previous || !next) return;

          button.disabled = true;
          previous.classList.remove('is-active');
          next.classList.add('is-active');
          panels.forEach((panel, index) => panel.setAttribute('aria-hidden', String(index !== active)));
          if (caption) caption.textContent = panels[active]?.dataset.caption ?? '';

          if (prefersReducedMotion) {
            button.disabled = false;
            return;
          }

          previous.classList.add('is-departing');
          let fallbackTimer: number | undefined;
          const finishSwap = () => {
            if (fallbackTimer) window.clearTimeout(fallbackTimer);
            previous.classList.remove('is-departing');
            button.disabled = false;
          };
          previous.addEventListener('animationend', finishSwap, { once: true });
          fallbackTimer = window.setTimeout(finishSwap, 600);
        });

        const supportsTilt = window.matchMedia('(hover: hover) and (pointer: fine)').matches;
        if (stack && supportsTilt && !prefersReducedMotion) {
          const resetTilt = () => {
            stack.style.setProperty('--portrait-tilt-x', '0deg');
            stack.style.setProperty('--portrait-tilt-y', '0deg');
          };
          stack.addEventListener('pointermove', (event) => {
            const bounds = stack.getBoundingClientRect();
            const x = (event.clientX - bounds.left) / bounds.width - 0.5;
            const y = (event.clientY - bounds.top) / bounds.height - 0.5;
            stack.style.setProperty('--portrait-tilt-x', `${(-y * 10).toFixed(2)}deg`);
            stack.style.setProperty('--portrait-tilt-y', `${(x * 10).toFixed(2)}deg`);
          });
          stack.addEventListener('pointerleave', resetTilt);
        }
      }
    };

    document.addEventListener('astro:page-load', initializeHome);
    initializeHome();
  </script>
</BaseLayout>
