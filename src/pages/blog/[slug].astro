---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import HomeReturn from '../../components/shell/HomeReturn.astro';
import WorldField from '../../components/shell/WorldField.astro';
import { sitePath } from '../../config/site';
import BaseDocument from '../../layouts/BaseDocument.astro';

export async function getStaticPaths() {
  const entries = await getCollection('writing', ({ data }) => !data.draft);

  return entries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

interface Props {
  entry: CollectionEntry<'writing'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const publishedAt = entry.data.publishedAt?.toLocaleDateString('en', {
  day: 'numeric',
  month: 'long',
  year: 'numeric',
});
---

<BaseDocument title={`${entry.data.title} | Igor Kupchinenko`} description={entry.data.summary}>
  <WorldField destination>
    <HomeReturn />
    <main id="main-content" class="article-main">
      <article class="writing-article" aria-labelledby="article-title">
        <svg class="writing-article__boundary" viewBox="0 0 1000 1400" preserveAspectRatio="none" aria-hidden="true">
          <path d="M35 21 C22 178 43 346 28 506 C18 675 39 835 25 1002 C17 1131 31 1255 23 1380" />
          <path class="writing-article__boundary-echo" d="M46 35 C37 192 54 349 41 516 C31 660 48 804 38 951" />
        </svg>

        <a class="writing-article__back" href={sitePath('/blog/')}>← Blog</a>

        <header>
          {publishedAt && <time datetime={entry.data.publishedAt?.toISOString()}>{publishedAt}</time>}
          <h1 id="article-title">{entry.data.title}</h1>
          <p>{entry.data.summary}</p>
        </header>

        <div class="writing-article__body">
          <Content />
        </div>

        {
          entry.data.canonicalUrl && (
            <footer>
              <a href={entry.data.canonicalUrl}>Originally published on Medium ↗</a>
            </footer>
          )
        }
      </article>
    </main>
  </WorldField>
</BaseDocument>

<style>
  .article-main {
    width: 100%;
    max-width: var(--destination-width);
    color: var(--color-field-ink);
    isolation: isolate;
  }

  .writing-article {
    position: relative;
    isolation: isolate;
    min-height: calc(100vh - (2 * var(--field-gutter)));
    padding: clamp(2.25rem, 6vw, 5rem) clamp(2rem, 9vw, 8rem) clamp(4rem, 8vw, 7rem);
    overflow: clip;
  }

  .writing-article__boundary {
    position: absolute;
    z-index: 0;
    inset: 0;
    width: 100%;
    height: 100%;
    overflow: visible;
    pointer-events: none;
  }

  .writing-article__boundary path {
    fill: none;
    stroke: rgba(243, 239, 228, 0.68);
    stroke-linecap: round;
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }

  .writing-article__boundary .writing-article__boundary-echo {
    stroke: rgba(243, 239, 228, 0.21);
    stroke-width: 1.1;
  }

  .writing-article__back,
  .writing-article header,
  .writing-article__body,
  .writing-article footer {
    position: relative;
    z-index: 1;
  }

  .writing-article__back {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    margin-bottom: clamp(2.5rem, 6vw, 5.5rem);
    color: rgba(243, 239, 228, 0.82);
    text-underline-offset: 0.24em;
  }

  .writing-article header {
    display: grid;
    gap: 1rem;
    max-width: 48rem;
    margin-bottom: clamp(3rem, 7vw, 6rem);
  }

  .writing-article time {
    color: rgba(243, 239, 228, 0.58);
    font-size: 0.9rem;
  }

  .writing-article h1 {
    max-width: 15ch;
    font-family: var(--font-distinctive);
    font-size: clamp(3rem, 7.5vw, 6.5rem);
    font-weight: 400;
    line-height: 0.98;
  }

  .writing-article header p {
    max-width: 58ch;
    color: rgba(243, 239, 228, 0.76);
    font-size: clamp(1.08rem, 1.9vw, 1.28rem);
    line-height: 1.65;
  }

  .writing-article__body {
    max-width: var(--reading-width);
    font-size: clamp(1.05rem, 1.6vw, 1.18rem);
    line-height: 1.78;
  }

  .writing-article__body :global(> * + *) {
    margin-top: 1.35em;
  }

  .writing-article__body :global(h2),
  .writing-article__body :global(h3) {
    margin-top: 2.4em;
    font-family: var(--font-distinctive);
    font-weight: 400;
    line-height: 1.12;
  }

  .writing-article__body :global(h2) {
    font-size: clamp(2rem, 4vw, 3rem);
  }

  .writing-article__body :global(h3) {
    font-size: clamp(1.55rem, 3vw, 2.2rem);
  }

  .writing-article__body :global(a),
  .writing-article footer a {
    color: inherit;
    text-decoration-thickness: 0.1rem;
    text-underline-offset: 0.24em;
  }

  .writing-article__body :global(blockquote) {
    position: relative;
    margin-block: 2rem;
    padding-left: clamp(1.25rem, 3vw, 2rem);
    color: rgba(243, 239, 228, 0.8);
  }

  .writing-article__body :global(blockquote)::before {
    position: absolute;
    top: 0.1rem;
    bottom: 0.1rem;
    left: 0;
    width: 0.12rem;
    background: rgba(243, 239, 228, 0.5);
    content: '';
    transform: rotate(0.5deg);
  }

  .writing-article__body :global(ul),
  .writing-article__body :global(ol) {
    padding-left: 1.4em;
  }

  .writing-article footer {
    max-width: var(--reading-width);
    margin-top: clamp(3.5rem, 8vw, 6rem);
    padding-top: 1.5rem;
    border-top: 0.1rem solid rgba(243, 239, 228, 0.35);
  }

  @media (max-width: 36rem) {
    .writing-article {
      padding: 1.5rem 1.15rem 3.5rem 1.35rem;
    }

    .writing-article__boundary {
      transform: translateX(-0.45rem);
    }

    .writing-article h1 {
      font-size: clamp(3rem, 15vw, 4.4rem);
    }
  }
</style>
