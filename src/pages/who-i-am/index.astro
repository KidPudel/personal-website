---
import { Image } from 'astro:assets';

import birdDoodle from '../../assets/art/doodles/Doodles_bird_1.png';
import cameraDoodle from '../../assets/art/doodles/Doodles_camera.png';
import robotDoodle from '../../assets/art/doodles/Doodles_robot.png';
import HomeReturn from '../../components/shell/HomeReturn.astro';
import PaperSurface from '../../components/shell/PaperSurface.astro';
import WorldField from '../../components/shell/WorldField.astro';
import ColorWord from '../../components/who/ColorWord.astro';
import CraftValues from '../../components/who/CraftValues.astro';
import PlayfulWord from '../../components/who/PlayfulWord.astro';
import PortraitInteraction from '../../components/who/PortraitInteraction.astro';
import { connectLinks } from '../../config/site';
import BaseDocument from '../../layouts/BaseDocument.astro';
---

<BaseDocument title="Who I am | Igor Kupchinenko" description="An introduction to Igor Kupchinenko and his craft values.">
  <WorldField destination>
    <HomeReturn />
    <main id="main-content" class="who-main">
      <PaperSurface variant="notebook" compact>
        <article class="who-page" aria-labelledby="who-title">
          <div class="who-page__doodles" aria-hidden="true">
            <Image class="who-page__bird" src={birdDoodle} alt="" width={190} />
            <Image class="who-page__camera" src={cameraDoodle} alt="" width={190} />
            <Image class="who-page__robot" src={robotDoodle} alt="" width={190} />
          </div>

          <section class="who-introduction">
            <div class="who-introduction__copy">
              <p class="who-introduction__hello">hello, I am Igor</p>
              <h1 id="who-title">I build <PlayfulWord word="experiences" />, then the systems that make them real.</h1>
              <p>
                I design and build interactive products and gameplay systems. I take someone's desire, carry it
                across technical boundaries, and fulfil it through something <ColorWord word="joyful" /> to interact with.
              </p>
            </div>

            <PortraitInteraction />
          </section>

          <CraftValues completionId="who-contact-sheet" />
        </article>
      </PaperSurface>

      <aside id="who-contact-sheet" class="who-contact-sheet" aria-live="polite" hidden>
        <p>I'd love to chat with you.</p>
        <div class="who-contact-sheet__links" aria-label="Connect options">
          {connectLinks.map((link) => <a href={link.href}>{link.label}</a>)}
        </div>
      </aside>
    </main>
  </WorldField>
</BaseDocument>

<style>
  .who-main {
    isolation: isolate;
  }

  .who-main :global(.paper-surface-frame) {
    position: relative;
    z-index: 2;
  }

  .who-page {
    position: relative;
    isolation: isolate;
  }

  .who-introduction {
    position: relative;
    z-index: 2;
    display: grid;
    grid-template-columns: minmax(0, 1.2fr) minmax(16rem, 0.8fr);
    align-items: center;
    gap: clamp(2rem, 4vw, 3.75rem);
    min-height: 31.5rem;
  }

  .who-introduction__copy {
    display: grid;
    gap: 1.1rem;
    max-width: 38rem;
  }

  .who-introduction__hello {
    width: fit-content;
    font-size: 1.05rem;
    transform: rotate(-1.5deg);
  }

  .who-introduction h1 {
    max-width: 16ch;
    font-family: var(--font-distinctive);
    font-size: clamp(2.4rem, 4.7vw, 4.5rem);
    font-weight: 400;
    line-height: 1.02;
  }

  .who-introduction__copy > p:not(.who-introduction__hello) {
    max-width: 52ch;
    font-size: clamp(1.1rem, 1.8vw, 1.3rem);
    line-height: 1.6;
  }

  .who-page__doodles {
    position: absolute;
    z-index: 1;
    inset: 0;
    pointer-events: none;
  }

  .who-page__doodles :global(img) {
    position: absolute;
    width: clamp(5.25rem, 9vw, 8rem);
    height: auto;
    object-fit: contain;
    filter: grayscale(1);
    opacity: 0.17;
  }

  .who-page__bird {
    top: -2rem;
    right: 37%;
    transform: rotate(-9deg);
  }

  .who-page__camera {
    right: -2.5rem;
    bottom: 28%;
    transform: rotate(8deg);
  }

  .who-page__robot {
    bottom: -3.5rem;
    left: -2rem;
    transform: rotate(-6deg);
  }

  .who-contact-sheet {
    position: relative;
    z-index: 1;
    width: min(74%, 42rem);
    max-width: calc(100% - 2rem);
    margin: -1.35rem auto 1rem;
    padding: 2.5rem 1.5rem 1.15rem;
    overflow: clip;
    background:
      linear-gradient(rgba(237, 225, 196, 0.9), rgba(242, 232, 207, 0.96)),
      var(--color-paper);
    box-shadow: 0 0.85rem 1.1rem rgba(7, 7, 6, 0.2);
    color: var(--color-ink);
    clip-path: polygon(
      0.4% 0.8%,
      15% 0.2%,
      33% 0.65%,
      51% 0.15%,
      69% 0.55%,
      86% 0.18%,
      99.6% 0.7%,
      99.85% 31%,
      99.55% 68%,
      99.7% 99.35%,
      79% 99.8%,
      58% 99.45%,
      37% 99.85%,
      16% 99.4%,
      0.3% 99.65%,
      0.1% 55%
    );
    scroll-margin-block: 1.5rem;
    transform-origin: top center;
  }

  .who-contact-sheet::before {
    position: absolute;
    z-index: -1;
    inset: 0;
    background: url('../../assets/art/paper-grain.svg') 0 0 / 180px 180px;
    content: '';
    mix-blend-mode: multiply;
    opacity: 0.12;
    pointer-events: none;
  }

  .who-contact-sheet[hidden] {
    display: none;
  }

  .who-contact-sheet:not([hidden]) {
    animation: contact-sheet-emerges 420ms cubic-bezier(0.2, 0.72, 0.28, 1) both;
  }

  .who-contact-sheet > p {
    font-size: clamp(1.2rem, 2vw, 1.55rem);
  }

  .who-contact-sheet__links {
    display: flex;
    max-width: 34rem;
    flex-wrap: wrap;
    gap: 0.1rem 1rem;
    margin-top: 0.35rem;
  }

  .who-contact-sheet__links a {
    display: inline-flex;
    min-height: 2.75rem;
    align-items: center;
    color: #864538;
    font-size: 0.95rem;
    text-decoration-thickness: 0.1rem;
    text-underline-offset: 0.24em;
  }

  @keyframes contact-sheet-emerges {
    from {
      opacity: 0.45;
      transform: translateY(-4.5rem) rotate(1.2deg) scale(0.985);
    }
    to {
      opacity: 1;
      transform: translateY(0) rotate(-0.65deg) scale(1);
    }
  }

  @media (max-width: 50rem) {
    .who-introduction {
      grid-template-columns: minmax(0, 1fr);
      gap: 3.5rem;
    }

    .who-introduction__copy {
      max-width: 42rem;
    }

    .who-page__bird {
      top: 28%;
      right: -2rem;
    }
  }

  @media (max-width: 36rem) {
    .who-introduction {
      min-height: auto;
    }

    .who-introduction h1 {
      font-size: clamp(2.4rem, 12.5vw, 3.7rem);
    }

    .who-page__doodles :global(img) {
      opacity: 0.12;
    }

    .who-page__camera {
      right: -2.8rem;
    }

    .who-contact-sheet {
      width: calc(100% - 1rem);
      max-width: none;
      margin-top: -1rem;
      padding: 2rem 1rem 0.9rem;
    }
  }

  @media (prefers-reduced-motion: reduce) {
    .who-contact-sheet:not([hidden]) {
      animation-duration: 0.01ms;
    }
  }
</style>
