---
import { getEntry } from 'astro:content';

import SiteFooter from '../components/SiteFooter.astro';
import SiteHeader from '../components/SiteHeader.astro';
import BaseLayout from '../layouts/BaseLayout.astro';

const performanceStory = await getEntry('work', 'high-load-service');
const orderingStory = await getEntry('work', 'ordering-platform');
if (!performanceStory || !orderingStory) throw new Error('Work content is missing.');

const base = import.meta.env.BASE_URL;
---

<BaseLayout page="work" title="Work | Igor Kupchinenko" description="Production software work by Igor Kupchinenko, focused on backend systems, data flow, APIs, and product delivery.">
  <div class="site-frame">
    <SiteHeader active="work" />
    <main id="main-content" class="notebook notebook-page work-page">
      <header class="page-hero work-hero">
        <p class="eyebrow"><span aria-hidden="true">✦</span> professional work</p>
        <h1>Production systems with consequences.</h1>
        <p>My strongest paid experience is in Go and backend engineering: stateful services, data flow, APIs, integrations, and finding out why production behaves differently from the diagram.</p>
        <div class="hero-links">
          <a class="button button-dark" href={`${base}resume/igor-kupchinenko-resume.pdf`}>Résumé PDF</a>
          <a class="button" href={`${base}resume/igor-kupchinenko-resume.docx`}>DOCX</a>
        </div>
      </header>

      <section class="work-stories" aria-label="Selected professional stories">
        <article class="work-story">
          <header><span>01</span><p>performance investigation</p></header>
          <div class="work-story-copy">
            <h2>{performanceStory.data.title}</h2>
            <p>{performanceStory.data.summary}</p>
            <ul>
              <li>Profiled the real execution path with pprof.</li>
              <li>Tuned goroutine behavior and connection pooling.</li>
              <li>Investigated and optimized SQL queries.</li>
            </ul>
          </div>
          <div class="work-result" aria-label="Latency reduced from 9.5 seconds to 650 milliseconds">
            <span>9.5s</span><b aria-hidden="true">→</b><strong>650ms</strong>
            <small>verified production result</small>
          </div>
        </article>

        <article class="work-story work-story-blue">
          <header><span>02</span><p>end-to-end ownership</p></header>
          <div class="work-story-copy">
            <h2>{orderingStory.data.title}</h2>
            <p>{orderingStory.data.summary}</p>
            <ul>
              <li>Translated stakeholder needs into working features.</li>
              <li>Worked across a Go backend and Flutter application.</li>
              <li>Carried implementation decisions into production operation.</li>
            </ul>
          </div>
          <div class="work-flow" aria-label="Work from requirements through production">
            <span>requirements</span><b>→</b><span>backend</span><b>→</b><span>production</span>
          </div>
        </article>
      </section>

      <aside class="privacy-strip">
        <strong>About the missing logos</strong>
        <p>The source code and company details are private. The problems, responsibilities, and approved result shown here are real.</p>
      </aside>
    </main>
    <SiteFooter />
  </div>
</BaseLayout>
