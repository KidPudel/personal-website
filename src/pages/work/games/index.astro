---
import { getCollection } from 'astro:content';

import HomeReturn from '../../../components/shell/HomeReturn.astro';
import WorldField from '../../../components/shell/WorldField.astro';
import WorkInventory from '../../../components/work/WorkInventory.astro';
import BaseDocument from '../../../layouts/BaseDocument.astro';

const order = [
  'discourses-by-campfire',
  'santa-foundation',
  'snake-raylib',
  'tic-tac-toe-opengl',
];
const entries = (await getCollection('games'))
  .filter((entry) => order.includes(entry.id))
  .sort((a, b) => order.indexOf(a.id) - order.indexOf(b.id));
---

<BaseDocument title="Games | Igor Kupchinenko" description="Games made by Igor Kupchinenko.">
  <WorldField destination>
    <HomeReturn />
    <main id="main-content" class="work-main">
      <WorkInventory
        current="games"
        title="Games"
        entries={entries}
      />
    </main>
  </WorldField>
</BaseDocument>

<style>
  .work-main {
    width: 100%;
    max-width: var(--destination-width);
    color: var(--color-field-ink);
  }
</style>
