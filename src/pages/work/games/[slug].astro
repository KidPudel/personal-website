---
import { type CollectionEntry, getCollection, render } from 'astro:content';

import HomeReturn from '../../../components/shell/HomeReturn.astro';
import PaperSurface from '../../../components/shell/PaperSurface.astro';
import WorldField from '../../../components/shell/WorldField.astro';
import ArtifactSketch from '../../../components/work/ArtifactSketch.astro';
import ProjectEvidence from '../../../components/work/ProjectEvidence.astro';
import BaseDocument from '../../../layouts/BaseDocument.astro';

export async function getStaticPaths() {
  const entries = await getCollection('games');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

interface Props {
  entry: CollectionEntry<'games'>;
}

const { entry } = Astro.props;
const { Content } = await render(entry);
const meta = [entry.data.engine, entry.data.jam].filter(Boolean).join(' · ');
---

<BaseDocument title={`${entry.data.title} | Igor Kupchinenko`} description={entry.data.summary}>
  <WorldField destination>
    <HomeReturn />
    <main id="main-content">
      <PaperSurface variant="work">
        <ProjectEvidence
          current="games"
          title={entry.data.title}
          summary={entry.data.summary}
          status={entry.data.status}
          meta={meta}
          externalUrl={entry.data.externalUrl}
        >
          <ArtifactSketch slot="sketch" category="games" slug={entry.id} />
          <Content />
        </ProjectEvidence>
      </PaperSurface>
    </main>
  </WorldField>
</BaseDocument>
